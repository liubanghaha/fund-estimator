<view class="container">
  <view wx:if="{{!isLoggedIn}}" class="empty-state">
    <view class="empty-icon">📈</view>
    <view class="empty-title">基金估算涨幅</view>
    <view class="empty-desc">追踪你的基金持仓，查看实时估值</view>
    <button class="login-btn" bind:tap="onLogin">微信授权登录</button>
  </view>

  <view wx:if="{{isLoggedIn}}" class="dashboard">
    <!-- 今日实时收益 -->
    <view class="asset-overview">
      <view class="asset-label">今日估算收益</view>
      <view class="asset-value {{todayProfit > 0 ? 'up' : todayProfit < 0 ? 'down' : ''}}">
        {{todayProfit > 0 ? '+' : ''}}{{todayProfit}}
      </view>
      <view class="asset-sub">
        <text>涨幅 {{todayProfitRate > 0 ? '+' : ''}}{{todayProfitRate}}%</text>
        <text class="asset-divider">|</text>
        <text>市值 {{totalAmount}}</text>
        <text class="asset-divider">|</text>
        <text class="{{totalReturn > 0 ? 'up' : totalReturn < 0 ? 'down' : ''}}">累计 {{totalReturn > 0 ? '+' : ''}}{{totalReturn}}</text>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="quick-actions">
      <view class="action-item" bind:tap="onSearch">
        <view class="action-icon">🔍</view>
        <view class="action-text">搜索基金</view>
      </view>
      <view class="action-item" bind:tap="onAdd">
        <view class="action-icon">📝</view>
        <view class="action-text">添加持仓</view>
      </view>
    </view>

    <!-- 收益走势图 -->
    <view wx:if="{{profitHistory.length > 1}}" class="chart-section">
      <view class="section-title">收益走势</view>
      <view class="chart-card">
        <canvas canvas-id="profitCanvas" id="profitCanvas" style="width:100%;height:360rpx"></canvas>
      </view>
    </view>

    <!-- 自选关注 -->
    <view wx:if="{{watchlist.length > 0}}" class="watchlist-section">
      <view class="section-title">自选关注</view>
      <view class="watchlist-scroll">
        <view wx:for="{{watchlist}}" wx:key="fundCode" class="watch-item" bind:tap="onTapWatchlist" data-code="{{item.fundCode}}" data-name="{{item.fundName}}">
          <view class="w-name">{{item.fundName}}</view>
          <view class="w-rate {{item.estimatedChangeRate > 0 ? 'up' : item.estimatedChangeRate < 0 ? 'down' : ''}}">
            {{item.estimatedChangeRate > 0 ? '+' : ''}}{{item.estimatedChangeRate !== null ? item.estimatedChangeRate : '--'}}%
          </view>
        </view>
      </view>
    </view>

    <!-- 持仓列表 -->
    <view wx:if="{{holdings.length > 0}}" class="holdings-section">
      <view class="section-title">持仓概览</view>
      <view wx:for="{{holdings}}" wx:key="_id" class="swipe-wrapper">
        <view class="swipe-delete" bind:tap="onDeleteHolding" data-id="{{item._id}}">删除</view>
        <view
          class="holding-item {{item._swiped ? 'swiped' : ''}}"
          bind:tap="onTapHolding"
          data-code="{{item.fundCode}}"
          data-name="{{item.fundName}}"
          data-id="{{item._id}}"
          data-index="{{index}}"
          bind:touchstart="onTouchStart"
          bind:touchend="onTouchEnd"
        >
          <view class="h-left">
            <view class="h-name">{{item.fundName}}</view>
            <view class="h-code">{{item.fundCode}}</view>
            <view class="h-nav">{{item.currentNav}}</view>
          </view>
          <view class="h-right">
            <view class="h-today {{item.todayChangeRate > 0 ? 'up' : item.todayChangeRate < 0 ? 'down' : ''}}">
              {{item.todayChangeRate > 0 ? '+' : ''}}{{item.todayChangeRate}}%
            </view>
            <view class="h-sub {{item.todayProfit > 0 ? 'up' : item.todayProfit < 0 ? 'down' : ''}}">
              {{item.todayProfit > 0 ? '+' : ''}}{{item.todayProfit}}
            </view>
            <view class="h-meta">市值 {{item.marketValue}}</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{updateTime}}" class="update-time">估值时间：{{updateTime}}</view>
  </view>
</view>
