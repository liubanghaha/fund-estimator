<view class="page-wrap {{theme === 'red' ? 'theme-red' : 'theme-blue'}}" style="height: {{pageHeight}}px">
  <scroll-view
    scroll-y
    class="page-scroll"
    refresher-enabled
    refresher-background="#F5F5F5"
    refresher-triggered="{{refresherTriggered}}"
    bindrefresherrefresh="onScrollRefresh"
  >
    <view class="container" style="padding-bottom: {{indexBarHeight}}rpx">

      <view wx:if="{{alertTriggered.length > 0}}" class="alert-bar">
        <text class="alert-icon">🔔</text>
        <text class="alert-text">{{alertTriggered.length}}只基金触发提醒</text>
        <text class="alert-close" bind:tap="onDismissAlert">✕</text>
      </view>
      <view wx:if="{{!isLoggedIn}}" class="empty-state">
        <view class="empty-icon">📈</view>
        <view class="empty-title">我的持仓</view>
        <view class="empty-desc">追踪你的基金持仓，查看实时估值</view>
        <button class="login-btn" bind:tap="onLogin">微信授权登录</button>
      </view>

      <view wx:elif="{{!dataReady}}" class="loading-inline"><text class="loading-text">加载中...</text></view>

      <view wx:elif="{{loadError}}" class="empty-state">
        <view class="empty-icon">🔌</view>
        <view class="empty-desc">网络异常，请检查网络后重试</view>
        <view class="empty-btns">
          <button class="login-btn" bind:tap="onScrollRefresh">点击重试</button>
        </view>
      </view>

      <view wx:elif="{{holdings.length === 0}}" class="empty-state">
        <view class="empty-desc">添加你的第一笔基金持仓，开始追踪收益</view>
        <view class="empty-demo-phone">
          <image class="empty-demo-img" src="/images/index_demo.png" mode="widthFix" />
          <view class="empty-demo-notch"></view>
          <view class="empty-demo-bar"></view>
        </view>
        <text class="empty-demo-tip">参考样例：支付宝 APP 持仓截图</text>
        <text class="empty-demo-sub-tip">识别结果可能有偏差，请核对后保存，或手动添加</text>
        <view class="empty-btns">
          <button class="login-btn" bind:tap="onScreenshotAdd">📷 截图添加基金</button>
          <button class="login-btn secondary" bind:tap="onSearch">🔍 搜索添加基金</button>
        </view>
      </view>

      <view wx:else class="dashboard">
        <view class="asset-overview" bind:tap="onTapProfit">
          <view class="amount-toggle" catch:tap="onToggleAmount">{{amountVisible ? '隐藏' : '显示'}}</view>
          <view class="asset-label">今日估算收益<text wx:if="{{allUpdated}}" class="updated-badge">✓</text></view>
          <view class="asset-value {{amountVisible ? (todayProfit > 0 ? 'up' : todayProfit < 0 ? 'down' : '') : ''}}">
            {{amountVisible ? (todayProfit > 0 ? '+' : '') + todayProfit : '****'}}
          </view>
          <view class="asset-sub">
            <text>涨幅 {{todayProfitRate > 0 ? '+' : ''}}{{todayProfitRate}}%</text>
            <text class="asset-divider">|</text>
            <text>市值 {{amountVisible ? totalAmount : '****'}}</text>
            <text class="asset-divider">|</text>
            <text class="{{amountVisible ? (totalReturn > 0 ? 'up' : totalReturn < 0 ? 'down' : '') : ''}}">累计 {{amountVisible ? (totalReturn > 0 ? '+' : '') + totalReturn : '****'}}</text>
          </view>
        </view>

        <view wx:if="{{batchMode}}" class="batch-top-bar">
          <text class="batch-top-cancel" bind:tap="onToggleBatch">取消</text>
          <text class="batch-top-title">已选 {{selectedCount}} 项</text>
          <view class="batch-top-right">
            <text wx:if="{{!allSelected}}" class="batch-top-link" bind:tap="onSelectAll">全选</text>
            <text wx:else class="batch-top-link" bind:tap="onSelectAll">取消全选</text>
            <text class="batch-top-delete" bind:tap="onBatchDelete">删除</text>
          </view>
        </view>

        <view wx:else class="quick-actions">
          <view class="action-item" bind:tap="onSearch">
            <view class="action-icon">🔍</view>
            <view class="action-text">搜索</view>
          </view>
          <view class="action-item" bind:tap="onAdd">
            <view class="action-icon">📝</view>
            <view class="action-text">新增</view>
          </view>
          <view class="action-item" bind:tap="onAdjust">
            <view class="action-icon">✏️</view>
            <view class="action-text">加减仓</view>
          </view>
          <view class="action-item" bind:tap="onCorrelation">
            <view class="action-icon">📊</view>
            <view class="action-text">资产分析</view>
          </view>
          <view class="action-item" bind:tap="onToggleBatch">
            <view class="action-icon">📋</view>
            <view class="action-text">批量</view>
          </view>
        </view>

        <view wx:if="{{holdings.length > 0}}" class="holdings-section">
          <scroll-view class="table-scroll" scroll-x enhanced show-scrollbar="{{false}}" enable-flex>
            <view class="table-inner">
              <view class="t-row t-head" bind:longpress="onLongPressHeader">
                <view class="t-cell t-name">基金名称<text class="t-hint">长按排序</text></view>
                <view wx:for="{{colOrder}}" wx:key="*this" wx:for-item="col"
                  class="t-cell {{colDefs[col].sortable && sortField === col ? 'active' : ''}} {{colDefs[col].isValuation ? 't-temp-header' : ''}}"
                  bind:tap="{{colDefs[col].sortable ? 'onSortTap' : 'onTempInfoTap'}}"
                  data-field="{{colDefs[col].sortable ? col : ''}}">
                  <text style="flex:1;text-align:right">{{colDefs[col].label}}</text><text wx:if="{{colDefs[col].sortable && sortField === col}}" style="font-size:18rpx">{{sortOrder === 'desc' ? '↓' : '↑'}}</text><text wx:if="{{colDefs[col].isValuation}}" class="t-temp-icon"> ⓘ</text>
                </view>
              </view>
              <view wx:for="{{holdings}}" wx:key="_id" class="t-row {{batchMode && item._checked ? 'selected' : ''}}"
                bind:tap="onTapHolding" bind:longpress="onLongPressHolding"
                data-code="{{item.fundCode}}" data-name="{{item.fundName}}" data-id="{{item._id}}">
                <view class="t-cell t-name">
                  <view wx:if="{{batchMode}}" class="batch-check {{item._checked ? 'checked' : ''}}" catch:tap="onToggleBatchSelect" data-index="{{index}}">{{item._checked ? '✓' : ''}}</view>
                  <view class="name-text">{{item.fundName}}</view>
                  <view class="code-text"><text wx:if="{{item.estimateUpdated}}" class="updated-tag">✓</text>{{item.fundCode}}</view>
                </view>
                <view wx:for="{{colOrder}}" wx:key="*this" wx:for-item="col" class="t-cell">
                  <block wx:if="{{col === 'todayProfit'}}">
                    <view class="t-val {{item.todayChangeRate > 0 ? 'up' : item.todayChangeRate < 0 ? 'down' : ''}}">{{item.todayChangeRate > 0 ? '+' : ''}}{{item.todayChangeRate}}%</view>
                    <view class="t-sub {{amountVisible ? (item.todayProfit > 0 ? 'up' : item.todayProfit < 0 ? 'down' : '') : ''}}">{{amountVisible ? (item.todayProfit > 0 ? '+' : '') + item.todayProfit : '****'}}</view>
                  </block>
                  <block wx:elif="{{col === 'totalReturn'}}">
                    <view class="t-val {{item.totalReturnRate > 0 ? 'up' : item.totalReturnRate < 0 ? 'down' : ''}}">{{item.totalReturnRate > 0 ? '+' : ''}}{{item.totalReturnRate}}%</view>
                    <view class="t-sub {{amountVisible ? (item.totalReturn > 0 ? 'up' : item.totalReturn < 0 ? 'down' : '') : ''}}">{{amountVisible ? (item.totalReturn > 0 ? '+' : '') + item.totalReturn : '****'}}</view>
                  </block>
                  <block wx:elif="{{col === 'valuation'}}">
                    <view wx:if="{{item.peTemp}}" class="t-val {{item.peTemp.signal === 'low' ? 't-low' : item.peTemp.signal === 'high' ? 't-high' : item.peTemp.signal === 'nodata' ? 't-nodata' : 't-mid'}}">{{item.peTemp.signal === 'low' ? '🟢低估' : item.peTemp.signal === 'high' ? '🔴高估' : item.peTemp.signal === 'nodata' ? '--' : '🟡正常'}}</view>
                    <view wx:elif="{{item.position != null}}" class="t-val {{item.position <= 30 ? 't-low' : item.position >= 70 ? 't-high' : 't-mid'}}">{{item.position <= 30 ? '🟢低估' : item.position >= 70 ? '🔴高估' : '🟡正常'}}</view>
                    <view wx:else class="t-val">--</view>
                    <view wx:if="{{item.peTemp && item.peTemp.signal !== 'nodata'}}" class="t-sub">{{item.peTemp.normPE}}</view>
                    <view wx:elif="{{item.navLow != null}}" class="t-sub">{{item.navLow}} ~ {{item.navHigh}}</view>
                  </block>
                </view>
              </view>
            </view>
          </scroll-view>
        </view>

        <view wx:if="{{updateTime}}" class="update-time">估值时间：{{updateTime}}</view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{isLoggedIn && indexCards.length > 0}}" class="index-bar">
    <view wx:if="{{showIndexEdit}}" class="index-edit-panel">
      <view class="idx-edit-header">
        <text class="idx-edit-title">选择显示的指数</text>
        <view class="idx-edit-done" bind:tap="onToggleIndexEdit">完成</view>
      </view>
      <view wx:for="{{ALL_INDICES}}" wx:key="code" class="idx-check-item" bind:tap="onToggleIndexItem" data-code="{{item.code}}">
        <view class="idx-checkbox {{editSelections[item.code] ? 'checked' : ''}}">{{editSelections[item.code] ? '✓' : ''}}</view>
        <text class="idx-check-label">{{item.name}}</text>
      </view>
      <view class="idx-edit-actions">
        <view class="idx-save-btn" bind:tap="onSaveIndexPrefs">保存</view>
      </view>
    </view>
    <view wx:elif="{{!indexExpanded}}" class="index-collapsed" bind:tap="onToggleIndex">
      <view class="index-card {{indexCards[0].isUp ? 'card-up' : 'card-down'}}" style="flex:1;padding:10rpx 24rpx;flex-direction:row;justify-content:space-between;align-items:center">
        <text class="ic-name" style="margin-bottom:0">{{indexCards[0].name}}</text>
        <text class="ic-price {{indexCards[0].isUp ? 'up' : 'down'}}" style="margin-bottom:0">{{indexCards[0].price}}</text>
        <text class="{{indexCards[0].isUp ? 'up' : 'down'}}" style="font-size:24rpx">{{indexCards[0].change}}</text>
        <text class="{{indexCards[0].isUp ? 'up' : 'down'}}" style="font-size:24rpx">{{indexCards[0].changeRate}}%</text>
        <text class="idx-expand-hint">▼</text>
      </view>
    </view>
    <view wx:elif="{{indexExpanded}}" class="index-expanded-panel">
      <view class="idx-expanded-top" bind:tap="onToggleIndex">
        <text class="idx-gear" catch:tap="onToggleIndexEdit">⚙</text>
        <text class="idx-expand-hint">▲</text>
      </view>
      <view class="index-scroll-anim {{indexExpanded ? 'open' : ''}}">
        <scroll-view scroll-x class="index-scroll" enhanced show-scrollbar="{{false}}" catch:tap="noop">
          <view wx:for="{{indexCards}}" wx:key="code" class="index-card {{item.isUp ? 'card-up' : 'card-down'}}">
            <view class="ic-name">{{item.name}}</view>
            <view class="ic-price {{item.isUp ? 'up' : 'down'}}">{{item.price}}</view>
            <view class="ic-change-row">
              <text class="{{item.isUp ? 'up' : 'down'}}">{{item.change}}</text>
              <text class="{{item.isUp ? 'up' : 'down'}}">  {{item.changeRate}}%</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <!-- 温度说明浮层（放在最外层，避免 scroll-view 内 fixed 失效） -->
  <view wx:if="{{showTempInfo}}" class="temp-tooltip-mask" bind:tap="onTempInfoTap">
    <view class="temp-tooltip-card" catch:tap="">
      <view class="temp-tooltip-arrow"></view>
      <view class="temp-tooltip-formula">基金估值 = 持仓股现价处于各自52周区间位置，按持仓占比加权</view>
      <view class="temp-tooltip-rule">{{lt}} 0.7 低估 | 0.7~1.3 正常 | {{gt}} 1.3 高估</view>
      <view class="temp-tooltip-source">数据来源：东方财富 · 每日更新</view>
      <view class="temp-tooltip-disclaimer">仅供参考，不构成投资建议</view>
    </view>
  </view>

  <!-- 列表头排序 -->
  <view wx:if="{{showColEdit}}" class="col-edit-mask" bind:tap="onCloseColEdit">
    <view class="col-edit-card" catch:tap="">
      <view class="col-edit-title">调整列表头顺序<text class="col-edit-hint">（长按表头触发）</text></view>
      <view wx:for="{{colOrder}}" wx:key="*this" class="col-edit-row">
        <text class="col-edit-name">{{colDefs[item].label}}</text>
        <view class="col-edit-btns">
          <text class="col-edit-btn {{index === 0 ? 'disabled' : ''}}" bind:tap="onColMoveUp" data-index="{{index}}">↑</text>
          <text class="col-edit-btn {{index === colOrder.length - 1 ? 'disabled' : ''}}" bind:tap="onColMoveDown" data-index="{{index}}">↓</text>
        </view>
      </view>
      <view class="col-edit-close" bind:tap="onCloseColEdit">完成</view>
    </view>
  </view>

  <!-- 止盈止损设置 -->
  <view wx:if="{{showAlertEdit}}" class="col-edit-mask" bind:tap="onCloseAlertEdit">
    <view class="col-edit-card" catch:tap="">
      <view class="col-edit-title">止盈止损提醒 — {{alertEditFundName}}</view>
      <view class="alert-field"><text class="alert-label">止盈(涨超%)</text><input class="alert-input" value="{{alertEditUpper}}" bindinput="onAlertUpper" type="digit" placeholder="例如15"/></view>
      <view class="alert-field"><text class="alert-label">止损(跌超%)</text><input class="alert-input" value="{{alertEditLower}}" bindinput="onAlertLower" type="digit" placeholder="例如-10"/></view>
      <view class="col-edit-close" bind:tap="onSaveAlert">保存</view>
    </view>
  </view>

  <!-- 版本更新日志 -->
  <view wx:if="{{showChangelog}}" class="changelog-mask" bind:tap="onCloseChangelog">
    <view class="changelog-card" catch:tap="">
      <view class="changelog-title">🎉 新版本更新</view>
      <view class="changelog-version">{{changelog.version}} · {{changelog.date}}</view>
      <view class="changelog-list">
        <view wx:for="{{changelog.items}}" wx:key="*this" class="changelog-item">{{item}}</view>
      </view>
      <view class="changelog-close" bind:tap="onCloseChangelog">知道了</view>
    </view>
  </view>
</view>
