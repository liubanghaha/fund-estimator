<view class="page-wrap {{theme === 'red' ? 'theme-red' : 'theme-blue'}}">
  <scroll-view scroll-y class="page-scroll"
    refresher-enabled refresher-background="#F5F5F5"
    refresher-triggered="{{refresherTriggered}}"
    bindrefresherrefresh="onScrollRefresh">

    <!-- 公众号关注引导 -->
    <view wx:if="{{isLoggedIn}}" class="oa-card">
      <view class="oa-text">📢 关注公众号，解锁更多功能</view>
      <view class="oa-hint">搜索「你的公众号名称」关注</view>
      <official-account></official-account>
    </view>

    <!-- 未登录 -->
    <view wx:if="{{!isLoggedIn}}" class="empty-state">
      <view class="empty-icon">📒</view>
      <view class="empty-title">理财笔记</view>
      <view class="empty-desc">简单记录记录，随时查看盈亏</view>
      <view class="empty-btns">
        <button class="login-btn" bind:tap="onLogin">微信一键登录</button>
      </view>
    </view>

    <!-- 空记录 -->
    <view wx:elif="{{dataReady && holdings.length === 0}}" class="empty-state">
      <view class="empty-icon">📝</view>
      <view class="empty-desc">添加你的第一笔记录</view>
      <view class="empty-hint">支持截图导入或手动录入</view>
      <view class="empty-btns">
        <button class="login-btn" bind:tap="onAdd">添加记录</button>
      </view>
    </view>

    <!-- 有数据 -->
    <view wx:else class="dashboard">
      <!-- 总成本卡片 -->
      <view class="cost-overview">
        <view class="amount-toggle" catch:tap="onToggleAmount">{{amountVisible ? '隐藏' : '显示'}}</view>
        <view class="cost-label">记录总成本</view>
        <view class="cost-value">{{amountVisible ? totalCost : '****'}}</view>
        <view class="cost-sub">共 {{holdings.length}} 条记录</view>
      </view>

      <!-- 批量栏 -->
      <view wx:if="{{batchMode}}" class="batch-top-bar">
        <text class="batch-top-cancel" bind:tap="onToggleBatch">取消</text>
        <text class="batch-top-title">已选 {{selectedCount}} 项</text>
        <view class="batch-top-right">
          <text wx:if="{{!allSelected}}" class="batch-top-link" bind:tap="onSelectAll">全选</text>
          <text wx:else class="batch-top-link" bind:tap="onSelectAll">取消全选</text>
          <text class="batch-top-link" bind:tap="onBatchMoveToGroup">移动分组</text>
          <text class="batch-top-delete" bind:tap="onBatchDelete">删除</text>
        </view>
      </view>

      <!-- 快捷操作 -->
      <view wx:else class="quick-actions">
        <view class="action-item" bind:tap="onAdd">
          <view class="action-icon">➕</view>
          <view class="action-text">添加</view>
        </view>
        <view class="action-item" bind:tap="onToggleBatch">
          <view class="action-icon">📋</view>
          <view class="action-text">批量管理</view>
        </view>
      </view>

      <!-- 分组标签 -->
      <view wx:if="{{holdings.length > 0}}" class="group-tabs-wrap">
        <scroll-view class="group-tabs" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="group-tab {{activeGroup === 'all' ? 'active' : ''}}" bind:tap="onGroupTap" data-group="all">全部 {{groupCounts.all || 0}}</view>
          <view class="group-tab {{activeGroup === 'ungrouped' ? 'active' : ''}}" bind:tap="onGroupTap" data-group="ungrouped">未分组 {{groupCounts.ungrouped || 0}}</view>
          <block wx:for="{{groups}}" wx:key="*this">
            <view class="group-tab {{activeGroup === item ? 'active' : ''}}" bind:tap="onGroupTap" data-group="{{item}}">{{item}} {{groupCounts[item] || 0}}</view>
          </block>
          <view class="group-tab group-tab-add" bind:tap="onAddGroup">+</view>
        </scroll-view>
      </view>

      <!-- 记录列表 -->
      <view wx:if="{{displayHoldings.length > 0}}" class="holdings-section">
        <view wx:for="{{displayHoldings}}" wx:key="_id"
          class="h-row {{batchMode && item._checked ? 'selected' : ''}}"
          bind:tap="onTapHolding"
          bind:longpress="onLongPressHolding"
          data-id="{{item._id}}" data-code="{{item.fundCode}}" data-name="{{item.fundName}}">
          <view wx:if="{{batchMode}}" class="batch-check {{item._checked ? 'checked' : ''}}" catch:tap="onToggleBatchSelect" data-index="{{index}}">{{item._checked ? '✓' : ''}}</view>
          <view class="h-info">
            <view class="h-name">
              <text wx:if="{{activeGroup === 'all' && item.group}}" class="group-tag">{{item.group}}</text>
              {{item.fundName}}
            </view>
            <view class="h-code">{{item.fundCode}}</view>
          </view>
          <view class="h-right">
            <view class="h-cost">{{amountVisible ? item.totalCost : '****'}}</view>
            <view class="h-shares">{{item.shares}} 份</view>
          </view>
        </view>
      </view>

      <view wx:elif="{{activeGroup !== 'all'}}" class="empty-group">
        <view class="empty-icon">📂</view>
        <view class="empty-desc">该分组暂无记录</view>
        <view class="empty-hint">长按记录可移动到本分组</view>
      </view>
    </view>
  </scroll-view>

  <!-- 手动盈亏计算浮层 -->
  <view wx:if="{{showCalc}}" class="calc-mask" bind:tap="onCloseCalc">
    <view class="calc-card" catch:tap="">
      <view class="calc-title">手动算盈亏 — {{calcName}}</view>
      <view class="calc-info">持有 {{calcShares}} 份 · 成本 {{calcCost}} 元</view>
      <view class="calc-field">
        <text class="calc-label">输入最新价格</text>
        <input class="calc-input" value="{{calcPrice}}" bindinput="onCalcPriceInput" type="digit" placeholder="输入当前价格" focus/>
      </view>
      <button class="calc-btn" bind:tap="onDoCalc">计算</button>
      <view wx:if="{{calcResult}}" class="calc-result">
        <view class="calc-result-row">当前市值：<text class="calc-result-val">{{calcResult.currentValue}} 元</text></view>
        <view class="calc-result-row">浮动盈亏：<text class="{{calcResult.isUp ? 'up' : 'down'}}">{{calcResult.isUp ? '+' : ''}}{{calcResult.profit}} 元 ({{calcResult.isUp ? '+' : ''}}{{calcResult.profitRate}}%)</text></view>
      </view>
    </view>
  </view>

  <!-- 移动分组选择器 -->
  <view wx:if="{{showGroupPicker}}" class="calc-mask" bind:tap="onCloseGroupPicker">
    <view class="picker-card" catch:tap="">
      <view class="picker-title">移动到分组</view>
      <scroll-view scroll-y style="max-height:480rpx;margin:16rpx 0">
        <view wx:for="{{groups}}" wx:key="*this" class="picker-item" bind:tap="onPickGroup" data-group="{{item}}">{{item}}</view>
        <view class="picker-item" bind:tap="onPickGroup" data-group="">📂 未分组</view>
      </scroll-view>
      <view class="picker-new-btn" bind:tap="onPickNewGroup">+ 新建分组</view>
      <view class="picker-close" bind:tap="onCloseGroupPicker">取消</view>
    </view>
  </view>
</view>
