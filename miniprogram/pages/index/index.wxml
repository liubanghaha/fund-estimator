<view class="page-wrap" style="height: {{pageHeight}}px">
  <scroll-view
    scroll-y
    class="page-scroll"
    refresher-enabled
    refresher-triggered="{{refresherTriggered}}"
    bindrefresherrefresh="onScrollRefresh"
    bindscrolltolower="onScrollToLower"
    lower-threshold="100"
  >
    <view class="container" style="padding-bottom: {{indexBarHeight}}rpx">
      <view wx:if="{{!isLoggedIn}}" class="empty-state">
        <view class="empty-icon">📈</view>
        <view class="empty-title">我的持仓</view>
        <view class="empty-desc">追踪你的基金持仓，查看实时估值</view>
        <button class="login-btn" bind:tap="onLogin">微信授权登录</button>
      </view>

      <view wx:elif="{{loading}}" class="skeleton-wrap">
        <view class="sk-asset skeleton"></view>
        <view class="sk-actions">
          <view class="sk-action-item skeleton"></view>
          <view class="sk-action-item skeleton"></view>
        </view>
        <view wx:for="{{[1,2,3]}}" wx:key="*this" class="sk-holding-item skeleton"></view>
      </view>

      <view wx:elif="{{holdings.length === 0}}" class="empty-state">
        <view class="empty-icon">📊</view>
        <view class="empty-title">暂无持仓</view>
        <view class="empty-desc">添加你的第一笔基金持仓，开始追踪收益</view>
        <view class="empty-btns">
          <button class="login-btn" bind:tap="onScreenshotAdd">📷 截图添加基金</button>
          <button class="login-btn secondary" bind:tap="onSearch">🔍 搜索添加基金</button>
        </view>
      </view>

      <view wx:else class="dashboard">
        <view class="asset-overview" bind:tap="onTapProfit">
          <view class="amount-toggle" catch:tap="onToggleAmount">{{amountVisible ? '隐藏' : '显示'}}</view>
          <view class="asset-label">今日估算收益</view>
          <view class="asset-value {{amountVisible ? (todayProfit > 0 ? 'up' : todayProfit < 0 ? 'down' : '') : ''}}">
            {{amountVisible ? (todayProfit > 0 ? '+' : '') + todayProfit : '****'}}
          </view>
          <view class="asset-sub">
            <text>涨幅 {{todayProfitRate > 0 ? '+' : ''}}{{todayProfitRate}}%</text>
            <text class="asset-divider">|</text>
            <text>市值 {{amountVisible ? totalAmount : '****'}}</text>
            <text class="asset-divider">|</text>
            <text class="{{amountVisible ? (totalReturn > 0 ? 'up' : totalReturn < 0 ? 'down' : '') : ''}}">累计 {{amountVisible ? (totalReturn > 0 ? '+' : '') + totalReturn : '****'}}</text>
          </view>
        </view>

        <view wx:if="{{batchMode}}" class="batch-top-bar">
          <text class="batch-top-cancel" bind:tap="onToggleBatch">取消</text>
          <text class="batch-top-title">已选 {{selectedCount}} 项</text>
          <view class="batch-top-right">
            <text wx:if="{{!allSelected}}" class="batch-top-link" bind:tap="onSelectAll">全选</text>
            <text wx:else class="batch-top-link" bind:tap="onSelectAll">取消全选</text>
            <text class="batch-top-delete" bind:tap="onBatchDelete">删除</text>
          </view>
        </view>

        <view wx:else class="quick-actions">
          <view class="action-item" bind:tap="onSearch">
            <view class="action-icon">🔍</view>
            <view class="action-text">搜索</view>
          </view>
          <view class="action-item" bind:tap="onAdd">
            <view class="action-icon">📝</view>
            <view class="action-text">新增</view>
          </view>
          <view class="action-item" bind:tap="onAdjust">
            <view class="action-icon">✏️</view>
            <view class="action-text">加减仓</view>
          </view>
          <view class="action-item" bind:tap="onToggleBatch">
            <view class="action-icon">📋</view>
            <view class="action-text">编辑</view>
          </view>
        </view>

        <view wx:if="{{holdings.length > 0}}" class="holdings-section">
          <view class="title-clip">
            <view class="title-row">
              <view class="t-left">持仓概览<text class="swipe-hint">← 左滑看更多</text></view>
              <view class="t-slide" style="transform:translateX({{listScrollX}}px);{{listSliding ? '' : 'transition:transform 0.25s ease'}}">
                <view class="c-mid hd-text {{sortField === 'todayProfit' ? 'active' : ''}}" bind:tap="onSortTap" data-field="todayProfit">当日收益{{sortField === 'todayProfit' ? (sortOrder === 'desc' ? ' ↓' : ' ↑') : ''}}</view>
                <view class="c-extra hd-text {{sortField === 'totalReturn' ? 'active' : ''}}" bind:tap="onSortTap" data-field="totalReturn">累计收益{{sortField === 'totalReturn' ? (sortOrder === 'desc' ? ' ↓' : ' ↑') : ''}}</view>
              </view>
            </view>
          </view>
          <view wx:for="{{holdings}}" wx:key="_id" class="card-clip {{batchMode && item._checked ? 'selected' : ''}}" wx:if="{{index < displayCount}}">
            <view
              class="card-scroll"
              bind:tap="{{batchMode ? 'onToggleBatchSelect' : 'onTapHolding'}}"
              data-code="{{item.fundCode}}"
              data-name="{{item.fundName}}"
              data-index="{{index}}"
              data-id="{{item._id}}"
              data-index="{{index}}"
              bind:touchstart="onTouchStart"
              bind:touchmove="onTouchMove"
              bind:touchend="onTouchEnd"
              bind:longpress="onLongPressHolding"
            >
              <view wx:if="{{batchMode}}" class="batch-check {{item._checked ? 'checked' : ''}}">{{item._checked ? '✓' : ''}}</view>
              <view class="card-left">
                <view class="card-row"><view class="c-name name-text">{{item.fundName}}<text wx:if="{{item.estimateUpdated}}" class="updated-tag">✓</text></view></view>
                <view class="card-row"><view class="c-name code-text">{{item.fundCode}}</view></view>
              </view>
              <view class="card-right" style="transform:translateX({{listScrollX}}px);{{listSliding ? '' : 'transition:transform 0.25s ease'}}">
                <view class="card-row">
                  <view class="c-mid value-text {{item.todayChangeRate > 0 ? 'up' : item.todayChangeRate < 0 ? 'down' : ''}}">
                    {{item.todayChangeRate > 0 ? '+' : ''}}{{item.todayChangeRate}}%
                  </view>
                  <view class="c-extra value-text {{item.totalReturnRate > 0 ? 'up' : item.totalReturnRate < 0 ? 'down' : ''}}">
                    {{item.totalReturnRate > 0 ? '+' : ''}}{{item.totalReturnRate}}%
                  </view>
                </view>
                <view class="card-row">
                  <view class="c-mid value-text {{amountVisible ? (item.todayProfit > 0 ? 'up' : item.todayProfit < 0 ? 'down' : '') : ''}}">
                    {{amountVisible ? (item.todayProfit > 0 ? '+' : '') + item.todayProfit : '****'}}
                  </view>
                  <view class="c-extra value-text {{amountVisible ? (item.totalReturn > 0 ? 'up' : item.totalReturn < 0 ? 'down' : '') : ''}}">
                    {{amountVisible ? (item.totalReturn > 0 ? '+' : '') + item.totalReturn : '****'}}
                  </view>
                </view>
              </view>
            </view>
          </view>
          <view wx:if="{{hasMore}}" class="load-more" bind:tap="loadMore">
            <text>查看更多持仓</text>
            <text class="load-more-count">（已显示{{displayCount}}/{{holdings.length}}）</text>
          </view>
        </view>

        <view wx:if="{{updateTime}}" class="update-time">估值时间：{{updateTime}}</view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{isLoggedIn && indexCards.length > 0}}" class="index-bar">
    <view wx:if="{{showIndexEdit}}" class="index-edit-panel">
      <view class="idx-edit-header">
        <text class="idx-edit-title">选择显示的指数</text>
        <text class="idx-edit-done" bind:tap="onToggleIndexEdit">完成</text>
      </view>
      <view wx:for="{{ALL_INDICES}}" wx:key="code" class="idx-check-item" bind:tap="onToggleIndexItem" data-code="{{item.code}}">
        <view class="idx-checkbox {{editSelections[item.code] ? 'checked' : ''}}">{{editSelections[item.code] ? '✓' : ''}}</view>
        <text class="idx-check-label">{{item.name}}</text>
      </view>
      <view class="idx-edit-actions">
        <text class="idx-save-btn" bind:tap="onSaveIndexPrefs">保存</text>
      </view>
    </view>
    <view wx:elif="{{!indexExpanded}}" class="index-collapsed" bind:tap="onToggleIndex">
      <text class="idx-name">{{indexCards[0].name}}</text>
      <text class="idx-price {{indexCards[0].isUp ? 'up' : 'down'}}">{{indexCards[0].price}}</text>
      <text class="idx-change {{indexCards[0].isUp ? 'up' : 'down'}}">{{indexCards[0].change}}</text>
      <text class="idx-change-rate {{indexCards[0].isUp ? 'up' : 'down'}}">{{indexCards[0].changeRate}}%</text>
      <text class="idx-expand-hint">▼</text>
    </view>
    <view wx:elif="{{indexExpanded}}" class="index-expanded-panel">
      <view class="idx-expanded-top" bind:tap="onToggleIndex">
        <text class="idx-gear" catch:tap="onToggleIndexEdit">⚙</text>
        <text class="idx-collapse-arrow">▲</text>
      </view>
      <scroll-view scroll-x class="index-scroll" enhanced show-scrollbar="{{false}}" catch:tap="noop">
        <view wx:for="{{indexCards}}" wx:key="code" class="index-card {{item.isUp ? 'card-up' : 'card-down'}}">
          <view class="ic-name">{{item.name}}</view>
          <view class="ic-price {{item.isUp ? 'up' : 'down'}}">{{item.price}}</view>
          <view class="ic-change-row">
            <text class="{{item.isUp ? 'up' : 'down'}}">{{item.change}}</text>
            <text class="{{item.isUp ? 'up' : 'down'}}">  {{item.changeRate}}%</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
