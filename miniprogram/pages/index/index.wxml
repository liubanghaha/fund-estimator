<view class="container">
  <view wx:if="{{!isLoggedIn}}" class="empty-state">
    <view class="empty-icon">📈</view>
    <view class="empty-title">我的持仓</view>
    <view class="empty-desc">追踪你的基金持仓，查看实时估值</view>
    <button class="login-btn" bind:tap="onLogin">微信授权登录</button>
  </view>

  <view wx:if="{{isLoggedIn}}" class="dashboard">
    <!-- 今日实时收益 -->
    <view class="asset-overview" bind:tap="onTapProfit">
      <view class="asset-label">今日估算收益</view>
      <view class="asset-value {{todayProfit > 0 ? 'up' : todayProfit < 0 ? 'down' : ''}}">
        {{todayProfit > 0 ? '+' : ''}}{{todayProfit}}
      </view>
      <view class="asset-sub">
        <text>涨幅 {{todayProfitRate > 0 ? '+' : ''}}{{todayProfitRate}}%</text>
        <text class="asset-divider">|</text>
        <text>市值 {{totalAmount}}</text>
        <text class="asset-divider">|</text>
        <text class="{{totalReturn > 0 ? 'up' : totalReturn < 0 ? 'down' : ''}}">累计 {{totalReturn > 0 ? '+' : ''}}{{totalReturn}}</text>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="quick-actions">
      <view class="action-item" bind:tap="onSearch">
        <view class="action-icon">🔍</view>
        <view class="action-text">搜索基金</view>
      </view>
      <view class="action-item" bind:tap="onAdd">
        <view class="action-icon">📝</view>
        <view class="action-text">添加持仓</view>
      </view>
    </view>

    <!-- 持仓列表 -->
    <view wx:if="{{holdings.length > 0}}" class="holdings-section">
      <view class="section-title">持仓概览 <text class="swipe-hint">← 左滑看更多</text></view>
      <view wx:for="{{holdings}}" wx:key="_id" class="card-clip">
        <view
          class="card-scroll"
          style="transform:translateX({{item._scrollX}}px);{{item._transition ? 'transition:transform 0.25s ease' : ''}}"
          bind:tap="onTapHolding"
          data-code="{{item.fundCode}}"
          data-name="{{item.fundName}}"
          data-id="{{item._id}}"
          data-index="{{index}}"
          bind:touchstart="onTouchStart"
          bind:touchmove="onTouchMove"
          bind:touchend="onTouchEnd"
          bind:longpress="onLongPressHolding"
        >
          <view class="card-table">
            <view class="card-row">
              <view class="c-name name-text">{{item.fundName}}</view>
              <view class="c-mid label-text">当日收益</view>
              <view class="c-extra label-text">累计收益</view>
            </view>
            <view class="card-row">
              <view class="c-name code-text">{{item.fundCode}}</view>
              <view class="c-mid value-text {{item.todayChangeRate > 0 ? 'up' : item.todayChangeRate < 0 ? 'down' : ''}}">
                {{item.todayChangeRate > 0 ? '+' : ''}}{{item.todayChangeRate}}%
              </view>
              <view class="c-extra value-text {{item.totalReturnRate > 0 ? 'up' : item.totalReturnRate < 0 ? 'down' : ''}}">
                {{item.totalReturnRate > 0 ? '+' : ''}}{{item.totalReturnRate}}%
              </view>
            </view>
            <view class="card-row">
              <view class="c-name code-text">{{item.currentNav}}</view>
              <view class="c-mid value-text {{item.todayProfit > 0 ? 'up' : item.todayProfit < 0 ? 'down' : ''}}">
                {{item.todayProfit > 0 ? '+' : ''}}{{item.todayProfit}}
              </view>
              <view class="c-extra value-text {{item.totalReturn > 0 ? 'up' : item.totalReturn < 0 ? 'down' : ''}}">
                {{item.totalReturn > 0 ? '+' : ''}}{{item.totalReturn}}
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{updateTime}}" class="update-time">估值时间：{{updateTime}}</view>
  </view>
</view>
