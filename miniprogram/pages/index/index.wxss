.page-wrap{display:flex;flex-direction:column;height:100vh;overflow:hidden;background:#F5F5F5}
.page-scroll{height:100%}

/* 公众号关注卡片 */
.oa-card{margin:16rpx 24rpx;padding:20rpx 24rpx;background:#FFF;border-radius:16rpx;display:flex;flex-direction:column;align-items:center}
.oa-text{font-size:26rpx;color:#666;margin-bottom:6rpx}
.oa-hint{font-size:22rpx;color:#BBB;margin-bottom:12rpx}

/* 空状态 */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48rpx;min-height:70vh}
.empty-icon{font-size:80rpx;margin-bottom:24rpx}
.empty-title{font-size:32rpx;font-weight:600;color:#333;margin-bottom:12rpx}
.empty-desc{font-size:26rpx;color:#999;text-align:center;line-height:1.6;margin-bottom:8rpx}
.empty-hint{font-size:24rpx;color:#BBB;text-align:center;margin-bottom:24rpx}
.empty-btns{display:flex;flex-direction:column;gap:16rpx;width:100%}
.login-btn{width:100%;height:88rpx;line-height:88rpx;font-size:32rpx;color:#FFF;background:var(--primary);border-radius:44rpx;text-align:center;padding:0}

/* 仪表盘 */
.dashboard{padding:0 24rpx 32rpx}

/* 成本卡片 */
.cost-overview{background:var(--primary-gradient);border-radius:16rpx;padding:36rpx 32rpx 32rpx;margin-bottom:16rpx;position:relative;color:#FFF;text-align:center}
.amount-toggle{position:absolute;right:24rpx;top:20rpx;font-size:22rpx;background:rgba(255,255,255,.25);padding:6rpx 16rpx;border-radius:20rpx;z-index:1}
.cost-label{font-size:24rpx;opacity:.85;margin-bottom:8rpx}
.cost-value{font-size:48rpx;font-weight:700;margin-bottom:12rpx}
.cost-sub{font-size:24rpx;opacity:.75}

/* 批量栏 */
.batch-top-bar{display:flex;align-items:center;justify-content:space-between;padding:16rpx 0;margin-bottom:8rpx}
.batch-top-cancel{font-size:26rpx;color:var(--primary)}
.batch-top-title{font-size:28rpx;font-weight:600;color:#333}
.batch-top-right{display:flex;gap:24rpx}
.batch-top-link{font-size:26rpx;color:var(--primary)}
.batch-top-delete{font-size:26rpx;color:#E4393C}

/* 快捷操作 */
.quick-actions{display:flex;justify-content:space-around;padding:22rpx 0;background:#FFF;border-radius:12rpx;margin:0 0 8rpx;border-bottom:1rpx solid #F5F5F5}
.action-item{display:flex;flex-direction:column;align-items:center;gap:8rpx}
.action-icon{font-size:40rpx}
.action-text{font-size:24rpx;color:#666}

/* 分组标签 */
.group-tabs-wrap{margin:0 0 8rpx;background:#FFF;border-radius:12rpx;padding:8rpx 0}
.group-tabs{white-space:nowrap;width:100%;padding:0 20rpx}
.group-tab{display:inline-flex;align-items:center;padding:12rpx 20rpx;margin-right:8rpx;font-size:24rpx;color:#888;background:#F5F5F5;border-radius:24rpx;white-space:nowrap}
.group-tab.active{color:#FFF;background:var(--primary);font-weight:500}
.group-tab-add{width:52rpx;height:52rpx;padding:0;justify-content:center;font-size:28rpx;font-weight:600;color:#BBB;border:1rpx dashed #DDD;background:transparent}

/* 持仓列表 */
.holdings-section{background:#FFF;border-radius:12rpx;overflow:hidden}
.h-row{display:flex;align-items:center;padding:24rpx 24rpx;border-bottom:1rpx solid #F5F5F5;background:#FFF}
.h-row:last-child{border-bottom:none}
.h-row.selected{outline:3rpx solid var(--primary);outline-offset:-3rpx}
.h-info{flex:1;overflow:hidden}
.h-name{font-size:28rpx;font-weight:500;color:#333;line-height:1.4;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.h-code{font-size:22rpx;color:#999;margin-top:4rpx}
.h-right{text-align:right;flex-shrink:0}
.h-cost{font-size:28rpx;font-weight:600;color:#333}
.h-shares{font-size:22rpx;color:#999;margin-top:4rpx}
.group-tag{font-size:18rpx;color:var(--primary);background:var(--primary-bg);padding:2rpx 8rpx;border-radius:6rpx;margin-right:6rpx;vertical-align:middle}
.batch-check{width:36rpx;height:36rpx;border:2rpx solid #CCC;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20rpx;margin-right:16rpx;flex-shrink:0}
.batch-check.checked{background:var(--primary);border-color:var(--primary);color:#FFF}

.empty-group{display:flex;flex-direction:column;align-items:center;padding:48rpx;background:#FFF;border-radius:12rpx}

/* 手动盈亏计算 */
.calc-mask{position:fixed;top:0;left:0;right:0;bottom:0;z-index:1001;background:rgba(0,0,0,.35);display:flex;align-items:center;justify-content:center}
.calc-card{width:560rpx;background:#FFF;border-radius:16rpx;padding:32rpx}
.calc-title{font-size:28rpx;font-weight:600;color:#333;margin-bottom:8rpx}
.calc-info{font-size:24rpx;color:#999;margin-bottom:20rpx}
.calc-field{display:flex;align-items:center;margin-bottom:20rpx}
.calc-label{width:160rpx;font-size:26rpx;color:#666}
.calc-input{flex:1;height:64rpx;border:1rpx solid #E5E5E5;border-radius:8rpx;padding:0 16rpx;font-size:28rpx}
.calc-btn{width:100%;height:80rpx;line-height:80rpx;background:var(--primary);color:#FFF;border-radius:44rpx;font-size:28rpx;text-align:center;padding:0;margin-bottom:16rpx}
.calc-result{border-top:1rpx solid #F5F5F5;padding-top:16rpx}
.calc-result-row{font-size:26rpx;color:#666;margin-bottom:8rpx}
.calc-result-val{font-weight:600;color:#333}
.up{color:#E4393C}
.down{color:#2E8B57}

/* 分组选择器 */
.picker-card{width:560rpx;background:#FFF;border-radius:16rpx;padding:32rpx}
.picker-title{font-size:28rpx;font-weight:600;color:#333;margin-bottom:8rpx}
.picker-item{padding:24rpx 16rpx;font-size:28rpx;color:#333;border-bottom:1rpx solid #F5F5F5;text-align:center}
.picker-new-btn{text-align:center;padding:20rpx;font-size:28rpx;color:var(--primary);border-top:1rpx solid #F5F5F5}
.picker-close{margin-top:16rpx;text-align:center;background:#F5F5F5;color:#666;border-radius:8rpx;padding:16rpx 0;font-size:26rpx}
