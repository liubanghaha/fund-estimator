.empty-state{text-align:center;padding-top:200rpx}
.empty-icon{font-size:100rpx;margin-bottom:32rpx}
.empty-title{font-size:40rpx;font-weight:600;color:#333;margin-bottom:16rpx}
.empty-desc{font-size:28rpx;color:#999;margin-bottom:60rpx}
.login-btn{width:400rpx;height:88rpx;line-height:88rpx;font-size:32rpx;color:#FFF;background:#07C160;border-radius:44rpx;text-align:center;padding:0}

.dashboard{padding-bottom:24rpx}

/* 今日收益卡片 */
.asset-overview{background:linear-gradient(135deg,#E4393C,#FF6B6B);padding:44rpx 32rpx;margin:24rpx;border-radius:16rpx;text-align:center;color:#FFF}
.asset-label{font-size:26rpx;opacity:.85;margin-bottom:14rpx}
.asset-value{font-size:64rpx;font-weight:700;margin-bottom:16rpx}
.asset-value.up{color:#FFD700}
.asset-value.down{color:#90EE90}
.asset-sub{font-size:26rpx;opacity:.9}
.asset-sub .up{color:#FFD700}
.asset-sub .down{color:#90EE90}
.asset-divider{margin:0 12rpx;opacity:.4}

/* 快捷入口 */
.quick-actions{display:flex;justify-content:space-around;padding:32rpx 24rpx;margin:0 24rpx;background:#FFF;border-radius:16rpx}
.action-item{text-align:center}
.action-icon{font-size:48rpx;margin-bottom:12rpx}
.action-text{font-size:26rpx;color:#333}

/* 收益走势 */
.chart-section{margin:24rpx}
.chart-card{background:#FFF;margin:0;border-radius:16rpx;padding:20rpx}

/* 持仓列表 */
.holdings-section{margin:24rpx}
.section-title{font-size:28rpx;font-weight:500;color:#333;margin-bottom:14rpx;padding-left:8rpx}

/* 左滑删除 */
.swipe-wrapper{position:relative;margin-bottom:10rpx;overflow:hidden;border-radius:16rpx}
.swipe-delete{
  position:absolute;top:0;right:0;bottom:0;
  width:160rpx;
  background:#E4393C;color:#FFF;
  font-size:28rpx;font-weight:500;
  display:flex;align-items:center;justify-content:center;
}
.holding-item{
  position:relative;z-index:1;
  display:flex;justify-content:space-between;align-items:center;
  padding:24rpx 28rpx;background:#FFF;border-radius:16rpx;
  transition:transform .2s ease;
}
.holding-item.swiped{transform:translateX(-160rpx)}
.h-left{flex:1}
.h-name{font-size:28rpx;font-weight:500;color:#333;margin-bottom:6rpx}
.h-code{font-size:22rpx;color:#999;margin-bottom:4rpx}
.h-nav{font-size:24rpx;color:#999}

.h-right{text-align:right}
.h-today{font-size:30rpx;font-weight:600;margin-bottom:4rpx}
.h-today.up{color:#E4393C}
.h-today.down{color:#2E8B57}
.h-sub{font-size:24rpx;margin-bottom:4rpx}
.h-sub.up{color:#E4393C}
.h-sub.down{color:#2E8B57}
.h-meta{font-size:22rpx;color:#CCC}

.update-time{text-align:center;font-size:22rpx;color:#CCC;padding:16rpx 0}
