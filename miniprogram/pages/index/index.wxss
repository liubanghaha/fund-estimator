.empty-state{text-align:center;padding-top:200rpx}
.empty-icon{font-size:100rpx;margin-bottom:32rpx}
.empty-title{font-size:40rpx;font-weight:600;color:#333;margin-bottom:16rpx}
.empty-desc{font-size:28rpx;color:#999;margin-bottom:60rpx}
.login-btn{width:400rpx;height:88rpx;line-height:88rpx;font-size:32rpx;color:#FFF;background:#07C160;border-radius:44rpx;text-align:center;padding:0}

.dashboard{padding-bottom:24rpx}

/* 今日收益卡片 */
.asset-overview{position:relative;background:linear-gradient(135deg,#E4393C,#FF6B6B);padding:36rpx 32rpx;margin:20rpx 24rpx;border-radius:16rpx;text-align:center;color:#FFF}
.amount-toggle{position:absolute;top:20rpx;right:24rpx;font-size:22rpx;color:rgba(255,255,255,.6);z-index:2}
.asset-label{font-size:24rpx;opacity:.85;margin-bottom:10rpx}
.asset-value{font-size:60rpx;font-weight:700;margin-bottom:12rpx}
.asset-value.up{color:#FFD700}
.asset-value.down{color:#90EE90}
.asset-sub{font-size:24rpx;opacity:.9}
.asset-sub .up{color:#FFD700}
.asset-sub .down{color:#90EE90}
.asset-divider{margin:0 10rpx;opacity:.4}

/* 快捷入口 */
.quick-actions{display:flex;justify-content:space-around;padding:20rpx 24rpx;margin:0 24rpx;background:#FFF;border-radius:12rpx}
.action-item{text-align:center}
.action-icon{font-size:36rpx;margin-bottom:6rpx}
.action-text{font-size:22rpx;color:#333}

/* 持仓列表 */
.holdings-section{margin:24rpx}
.section-title{font-size:28rpx;font-weight:500;color:#333;margin-bottom:14rpx;padding-left:8rpx}
.swipe-hint{font-size:22rpx;color:#CCC;font-weight:400;margin-left:8rpx}

/* 可左右滑动的卡片 */
.card-clip{
  margin-bottom:12rpx;
  border-radius:16rpx;
  overflow:hidden;
}
.card-scroll{
  width:calc(100% + 260rpx);
  background:#FFF;
  border-radius:16rpx;
  padding:28rpx 0;
}

/* 行式布局：每行内容天然对齐 */
.card-table{width:100%}
.card-row{
  display:flex;
  align-items:baseline;
}
.card-row + .card-row{margin-top:18rpx}

.c-name{flex:1;min-width:0;padding-left:28rpx}

.c-mid{
  flex-shrink:0;width:170rpx;
  text-align:right;padding-right:24rpx;
}

.c-extra{
  flex-shrink:0;width:220rpx;
  text-align:right;
  padding:0 20rpx;
  border-left:1rpx solid #F0F0F0;
}

.label-text{font-size:26rpx;font-weight:600;color:#E4393C;line-height:1}
.name-text{font-size:26rpx;font-weight:500;color:#333;line-height:1}
.code-text{font-size:24rpx;color:#999;line-height:1}
.value-text{font-size:26rpx;font-weight:600;line-height:1}
.up{color:#E4393C}
.down{color:#2E8B57}

/* 加载更多 */
.load-more{text-align:center;padding:28rpx 0;font-size:26rpx;color:#999}
.load-more-count{font-size:22rpx;color:#CCC;margin-left:8rpx}

.update-time{text-align:center;font-size:22rpx;color:#CCC;padding:16rpx 0}
