.page{min-height:100vh;background:#F5F5F5;padding-bottom:40rpx}

.loading-wrap{display:flex;align-items:center;justify-content:center;padding-top:200rpx}
.loading-text{font-size:28rpx;color:#999}

/* 骨架屏 */
.skeleton-wrap{padding:24rpx}
.sk-summary-bar{display:flex;gap:12rpx;margin-bottom:16rpx}
.sk-summary-item{flex:1;height:120rpx;border-radius:12rpx}
.sk-chart{height:360rpx;border-radius:20rpx;margin-bottom:16rpx}
.sk-tabbar{height:80rpx;border-radius:20rpx;margin-bottom:16rpx}
.sk-calendar{height:500rpx;border-radius:20rpx}

/* 空状态 */
.empty-wrap{display:flex;flex-direction:column;align-items:center;padding-top:160rpx}
.empty-icon{font-size:80rpx;margin-bottom:24rpx}
.empty-text{font-size:30rpx;color:#999;margin-bottom:12rpx}
.empty-hint{font-size:24rpx;color:#CCC;margin-bottom:48rpx}
.empty-btn{width:240rpx;height:72rpx;line-height:72rpx;font-size:26rpx;color:#FFF;background:#E4393C;border-radius:36rpx;text-align:center;padding:0}
.tip-inline{font-size:20rpx;color:#BBB;text-align:center;padding:8rpx 24rpx 4rpx}

.summary-bar{display:flex;background:#FFF;padding:16rpx 16rpx;margin-bottom:16rpx}
.summary-item{flex:1;text-align:center;padding:12rpx 4rpx;border-radius:12rpx;transition:all .2s;margin-right:6rpx}
.summary-item:last-child{margin-right:0}
.summary-item.active{background:linear-gradient(135deg,#E4393C,#FF6B6B)}
.summary-item.active .summary-label{color:rgba(255,255,255,.8)}
.summary-item.active .summary-value{color:#FFF}
.summary-item.active .summary-value.up{color:#FFD700}
.summary-item.active .summary-value.down{color:#90EE90}
.summary-label{font-size:20rpx;color:#999;margin-bottom:4rpx}
.summary-value{font-size:28rpx;font-weight:600;color:#333}
.summary-value.up{color:#E4393C}
.summary-value.down{color:#2E8B57}
.summary-rate{font-size:18rpx;color:#999;margin-top:2rpx}
.summary-rate.up{color:#E4393C}
.summary-rate.down{color:#2E8B57}
.summary-item.active .summary-rate{color:rgba(255,255,255,.7)}
.summary-item.active .summary-rate.up{color:#FFD700}
.summary-item.active .summary-rate.down{color:#90EE90}

.chart-card{background:#FFF;margin:16rpx 24rpx;border-radius:20rpx;padding:24rpx 16rpx 16rpx}
.chart-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx;padding-left:8rpx}
.chart-title{font-size:26rpx;font-weight:600;color:#1A1A1A}
.compare-picker{font-size:24rpx;color:#1976D2;padding:8rpx 16rpx;background:rgba(25,118,210,0.06);border-radius:8rpx}
.index-options{display:flex;gap:4rpx;flex-wrap:wrap}
.index-opt{font-size:20rpx;color:#999;padding:4rpx 10rpx;border-radius:16rpx;background:#F5F5F5}
.index-opt.active{color:#1976D2;background:rgba(25,118,210,0.08);font-weight:500}

.cal-top-row{display:flex;justify-content:space-between;align-items:center;background:#FFF;margin:0 24rpx;padding:20rpx 24rpx 8rpx;border-radius:20rpx 20rpx 0 0}
.cal-title{font-size:28rpx;font-weight:600;color:#1A1A1A}
.cal-mode-toggle{font-size:22rpx;color:#1976D2;padding:6rpx 16rpx;background:rgba(25,118,210,0.06);border-radius:16rpx}

.tab-bar{display:flex;align-items:center;gap:16rpx;background:#FFF;margin:0 24rpx;border-radius:0;padding:16rpx 24rpx;border-bottom:1rpx solid #F0F0F0}
.tab-item{font-size:26rpx;color:#999;padding:8rpx 0;position:relative}
.tab-item.active{color:#E4393C;font-weight:600}
.tab-item.active::after{content:'';position:absolute;bottom:-17rpx;left:50%;transform:translateX(-50%);width:32rpx;height:4rpx;background:#E4393C;border-radius:2rpx}
.tab-picker{margin-left:auto}
.picker-label{font-size:24rpx;color:#666;padding:10rpx 14rpx;background:#F5F5F5;border-radius:8rpx}
.cal-header{display:flex;justify-content:center;padding:0 0 16rpx}
/* 日历 */
.calendar-card{background:#FFF;margin:0 24rpx;border-radius:0 0 20rpx 20rpx;padding:16rpx 16rpx 24rpx}

.day-grid{display:grid;grid-template-columns:repeat(7,1fr);padding:8rpx 0 12rpx}
.weekday{text-align:center;font-size:22rpx;color:#BBB;padding-bottom:12rpx}

.day-cell{text-align:center;padding:12rpx 2rpx;min-height:90rpx;display:flex;flex-direction:column;align-items:center;justify-content:center}
.day-profit{font-size:20rpx;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.day-cell.empty{opacity:.4}
.day-cell.empty .day-num{font-size:20rpx;color:#CCC}
.day-cell.up .day-num,.day-cell.down .day-num{font-size:26rpx;color:#333;font-weight:500}
.day-num{font-size:20rpx;color:#CCC;margin-bottom:2rpx}
.day-profit.up{color:#E4393C}
.day-profit.down{color:#2E8B57}

/* 月网格 */
.month-grid{display:flex;flex-wrap:wrap;padding:8rpx 0}
.month-cell{width:25%;text-align:center;padding:24rpx 0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.month-cell.empty{opacity:.25}
.month-name{font-size:26rpx;color:#333;margin-bottom:8rpx}
.month-profit{font-size:24rpx;font-weight:500}
.month-profit.up{color:#E4393C}
.month-profit.down{color:#2E8B57}
.empty-text{font-size:24rpx;color:#CCC}

/* 年列表 */
.year-list{padding:8rpx 0}
.year-row{display:flex;justify-content:space-between;align-items:center;padding:24rpx 8rpx;border-bottom:1rpx solid #F5F5F5}
.year-row:last-child{border-bottom:none}
.year-label{font-size:30rpx;font-weight:500;color:#333}
.year-profit{font-size:30rpx;font-weight:600}
.year-profit.up{color:#E4393C}
.year-profit.down{color:#2E8B57}
