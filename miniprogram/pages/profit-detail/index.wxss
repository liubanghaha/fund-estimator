.page{min-height:100vh;background:#F5F5F5;padding-bottom:40rpx}

.loading-wrap{display:flex;align-items:center;justify-content:center;padding-top:200rpx}
.loading-text{font-size:28rpx;color:#999}

.summary-bar{display:flex;background:#FFF;padding:32rpx 24rpx;margin-bottom:16rpx}
.summary-item{flex:1;text-align:center}
.summary-label{font-size:24rpx;color:#999;margin-bottom:10rpx}
.summary-value{font-size:36rpx;font-weight:600;color:#333}
.summary-value.up{color:#E4393C}
.summary-value.down{color:#2E8B57}

.chart-card{background:#FFF;margin:16rpx 24rpx;border-radius:20rpx;padding:24rpx 16rpx 16rpx}
.chart-title{font-size:28rpx;font-weight:600;color:#1A1A1A;margin-bottom:12rpx;padding-left:8rpx}
.profit-canvas{width:680rpx;height:360rpx;display:block;margin:0 auto}

.tab-bar{display:flex;align-items:center;background:#FFF;margin:0 24rpx;border-radius:20rpx 20rpx 0 0;overflow:hidden;padding-right:16rpx}
.tab-item{flex:1;text-align:center;padding:24rpx 0;font-size:28rpx;color:#999}
.tab-item.active{color:#E4393C;font-weight:600;border-bottom:4rpx solid #E4393C}
.tab-toggle{flex-shrink:0;padding:12rpx 20rpx;font-size:24rpx;color:#E4393C;border:1rpx solid #E4393C;border-radius:24rpx}
.toggle-arrow{font-size:16rpx;margin-left:4rpx}

.table-card{background:#FFF;margin:0 24rpx;border-radius:0 0 20rpx 20rpx;padding:0 28rpx 16rpx}
.table-header{display:flex;padding:20rpx 0 12rpx;border-bottom:1rpx solid #F0F0F0}
.table-header view{font-size:24rpx;color:#999}
.table-row{display:flex;padding:18rpx 0;border-bottom:1rpx solid #F8F8F8}
.table-row:last-child{border-bottom:none}
.th-date{width:140rpx}
.th-profit{flex:1;text-align:right}
.td-date{width:140rpx;font-size:26rpx;color:#666}
.td-profit{flex:1;text-align:right;font-size:26rpx;font-weight:500;color:#333}
.td-profit.up{color:#E4393C}
.td-profit.down{color:#2E8B57}
