<view class="page {{theme === 'red' ? 'theme-red' : 'theme-blue'}}">
  <view wx:if="{{loading}}" class="loading-inline"><text class="loading-text">加载中...</text></view>
  <view wx:elif="{{loadError}}" class="empty-wrap">
    <view class="empty-icon">😵</view>
    <view class="empty-text">加载失败</view>
    <button class="retry-btn" bind:tap="onRetry">点击重试</button>
  </view>
  <block wx:elif="{{empty}}">
    <view class="empty-wrap">
      <view class="empty-icon">📉</view>
      <view class="empty-text">暂无收益数据</view>
      <view class="empty-hint">添加持仓后可查看收益走势</view>
      <button class="empty-btn" bind:tap="onGoHome">返回首页</button>
    </view>
  </block>

    <block wx:else>
    <view wx:if="{{activeTab !== 'today' && earliestDate}}" class="tip-inline">收益自 {{earliestDate}} 起计，随交易日积累</view>
    <!-- 收益摘要：当天/本周/本月/本年 -->
    <view class="summary-bar">
      <view class="summary-item {{activeTab === 'today' ? 'active' : ''}}" bind:tap="onSummaryTap" data-tab="today">
        <view class="summary-label">当天收益</view>
        <view class="summary-value {{todayProfit > 0 ? 'up' : todayProfit < 0 ? 'down' : ''}}">
          {{todayProfit > 0 ? '+' : ''}}{{todayProfit}}
        </view>
        <view class="summary-rate {{todayProfitRate > 0 ? 'up' : todayProfitRate < 0 ? 'down' : ''}}">
          {{todayProfitRate > 0 ? '+' : ''}}{{todayProfitRate}}%
        </view>
      </view>
      <view class="summary-item {{activeTab === 'week' ? 'active' : ''}}" bind:tap="onSummaryTap" data-tab="week">
        <view class="summary-label">本周收益</view>
        <view class="summary-value {{weekProfit > 0 ? 'up' : weekProfit < 0 ? 'down' : ''}}">
          {{weekProfit > 0 ? '+' : ''}}{{weekProfit}}
        </view>
        <view class="summary-rate {{weekProfitRate > 0 ? 'up' : weekProfitRate < 0 ? 'down' : ''}}">
          {{weekProfitRate > 0 ? '+' : ''}}{{weekProfitRate}}%
        </view>
      </view>
      <view class="summary-item {{activeTab === 'month' ? 'active' : ''}}" bind:tap="onSummaryTap" data-tab="month">
        <view class="summary-label">本月收益</view>
        <view class="summary-value {{monthProfit > 0 ? 'up' : monthProfit < 0 ? 'down' : ''}}">
          {{monthProfit > 0 ? '+' : ''}}{{monthProfit}}
        </view>
        <view class="summary-rate {{monthProfitRate > 0 ? 'up' : monthProfitRate < 0 ? 'down' : ''}}">
          {{monthProfitRate > 0 ? '+' : ''}}{{monthProfitRate}}%
        </view>
      </view>
      <view class="summary-item {{activeTab === 'year' ? 'active' : ''}}" bind:tap="onSummaryTap" data-tab="year">
        <view class="summary-label">本年收益</view>
        <view class="summary-value {{yearProfit > 0 ? 'up' : yearProfit < 0 ? 'down' : ''}}">
          {{yearProfit > 0 ? '+' : ''}}{{yearProfit}}
        </view>
        <view class="summary-rate {{yearProfitRate > 0 ? 'up' : yearProfitRate < 0 ? 'down' : ''}}">
          {{yearProfitRate > 0 ? '+' : ''}}{{yearProfitRate}}%
        </view>
      </view>
    </view>

    <!-- 走势图 -->
    <view class="chart-card">
      <view class="chart-header">
        <view class="chart-title">{{activeTab === 'today' ? '当天' : activeTab === 'week' ? '本周' : activeTab === 'month' ? '本月' : '本年'}}走势</view>
        <view class="index-options">
          <view wx:for="{{availableIndices}}" wx:key="code" wx:for-item="idx"
            wx:if="{{idx.code !== '000300'}}"
            class="index-opt {{compareIndex === idx.code ? 'active' : ''}}"
            bind:tap="onSelectIndex" data-code="{{idx.code}}" data-name="{{idx.name}}">
            {{idx.name}}
          </view>
          <view class="index-opt {{compareIndex === '000300' ? 'active' : ''}}"
            bind:tap="onSelectIndex" data-code="000300" data-name="沪深300">
            沪深300
          </view>
        </view>
      </view>
      <canvas type="2d" id="profitCanvas" style="width:100%;height:{{canvasHRpx}}rpx" bindtouchstart="onCanvasTouch" bindtouchmove="onCanvasTouch" bindtouchend="onCanvasTouch"></canvas>
    </view>

    <!-- 盈亏日历 -->
    <view class="cal-top-row">
      <view class="cal-title">盈亏日历</view>
      <view class="cal-mode-toggle" bind:tap="onToggleMode">{{profitMode === 'amount' ? '收益率' : '收益金额'}}</view>
    </view>
    <view class="tab-bar">
        <view class="tab-item {{calendarView === 'day' ? 'active' : ''}}" bind:tap="onCalendarTab" data-tab="day">日</view>
        <view class="tab-item {{calendarView === 'month' ? 'active' : ''}}" bind:tap="onCalendarTab" data-tab="month">月</view>
        <view class="tab-item {{calendarView === 'year' ? 'active' : ''}}" bind:tap="onCalendarTab" data-tab="year">年</view>
        <view wx:if="{{calendarView === 'day'}}" class="tab-picker">
          <picker mode="selector" range="{{availableMonths}}" bindchange="onMonthChange">
            <view class="picker-label">{{selectedMonth}} ▼</view>
          </picker>
        </view>
        <view wx:if="{{calendarView === 'month'}}" class="tab-picker">
          <picker mode="selector" range="{{availableYears}}" bindchange="onYearChange">
            <view class="picker-label">{{selectedYear}} ▼</view>
          </picker>
        </view>
      </view>

    <!-- 日视图 -->
    <view wx:if="{{calendarView === 'day'}}" class="calendar-card">
      <view class="day-grid">
        <view class="weekday">日</view><view class="weekday">一</view><view class="weekday">二</view>
        <view class="weekday">三</view><view class="weekday">四</view><view class="weekday">五</view><view class="weekday">六</view>
        <block wx:for="{{dayCalendar}}" wx:for-item="row" wx:key="index">
          <view wx:for="{{row}}" wx:for-item="d" wx:for-index="di" wx:key="di"
            class="day-cell {{d.empty ? 'empty' : (d.profit > 0 ? 'up' : d.profit < 0 ? 'down' : '')}}">
            <view class="day-num">{{d.day}}</view>
            <view wx:if="{{!d.empty && d.profit !== null}}" class="day-profit {{d.profit > 0 ? 'up' : d.profit < 0 ? 'down' : ''}}">
              {{profitMode === 'rate' ? (d.rate > 0 ? '+' : '') + d.rate + '%' : (d.profit > 0 ? '+' : '') + d.profit}}
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 月视图 -->
    <view wx:if="{{calendarView === 'month'}}" class="calendar-card">
      <view class="month-grid">
        <view wx:for="{{monthCalendar}}" wx:key="month" class="month-cell {{item.empty ? 'empty' : (item.profit > 0 ? 'up' : item.profit < 0 ? 'down' : '')}}">
          <view class="month-name">{{item.month}}月</view>
          <view wx:if="{{!item.empty && item.profit !== null}}" class="month-profit {{item.profit > 0 ? 'up' : item.profit < 0 ? 'down' : ''}}">
            {{profitMode === 'rate' ? (item.rate > 0 ? '+' : '') + item.rate + '%' : (item.profit > 0 ? '+' : '') + item.profit}}
          </view>
          <view wx:else class="month-profit empty-text">--</view>
        </view>
      </view>
    </view>

    <!-- 年视图 -->
    <view wx:if="{{calendarView === 'year'}}" class="calendar-card">
      <view class="year-list">
        <view wx:for="{{yearData}}" wx:key="date" class="year-row {{item.profit > 0 ? 'up' : item.profit < 0 ? 'down' : ''}}">
          <view class="year-label">{{item.date.slice(0, 4)}}年</view>
          <view class="year-profit {{item.profit > 0 ? 'up' : item.profit < 0 ? 'down' : ''}}">
            {{profitMode === 'rate' ? (item.rate > 0 ? '+' : '') + item.rate + '%' : (item.profit > 0 ? '+' : '') + item.profit}}
          </view>
        </view>
      </view>
    </view>
    </block>
</view>
