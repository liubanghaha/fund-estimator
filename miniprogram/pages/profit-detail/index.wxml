<view class="page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:else>
    <view class="summary-bar">
      <view class="summary-item">
        <view class="summary-label">当日收益</view>
        <view class="summary-value {{todayProfit > 0 ? 'up' : todayProfit < 0 ? 'down' : ''}}">
          {{todayProfit > 0 ? '+' : ''}}{{todayProfit}}
        </view>
      </view>
      <view class="summary-item">
        <view class="summary-label">本月收益</view>
        <view class="summary-value {{monthProfit > 0 ? 'up' : monthProfit < 0 ? 'down' : ''}}">
          {{monthProfit > 0 ? '+' : ''}}{{monthProfit}}
        </view>
      </view>
      <view class="summary-item">
        <view class="summary-label">本年收益</view>
        <view class="summary-value {{yearProfit > 0 ? 'up' : yearProfit < 0 ? 'down' : ''}}">
          {{yearProfit > 0 ? '+' : ''}}{{yearProfit}}
        </view>
      </view>
    </view>

    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'day' ? 'active' : ''}}" bind:tap="onTabTap" data-tab="day">当日</view>
      <view class="tab-item {{activeTab === 'month' ? 'active' : ''}}" bind:tap="onTabTap" data-tab="month">本月</view>
      <view class="tab-item {{activeTab === 'year' ? 'active' : ''}}" bind:tap="onTabTap" data-tab="year">本年</view>
    </view>

    <view class="chart-card">
      <view wx:if="{{activeTab === 'day' && dayData.length < 2}}" class="empty-text">暂无当日数据</view>
      <view wx:elif="{{activeTab === 'month' && monthData.length < 2}}" class="empty-text">暂无本月数据</view>
      <view wx:elif="{{activeTab === 'year' && yearData.length < 2}}" class="empty-text">暂无本年数据</view>
      <canvas wx:else canvas-id="profitCanvas" id="profitCanvas" style="width:100%;height:360rpx"></canvas>
    </view>
  </view>
</view>
