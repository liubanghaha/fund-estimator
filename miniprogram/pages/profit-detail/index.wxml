<view class="page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:else>
    <view class="summary-bar">
      <view class="summary-item">
        <view class="summary-label">当日收益</view>
        <view class="summary-value {{todayProfit > 0 ? 'up' : todayProfit < 0 ? 'down' : ''}}">
          {{todayProfit > 0 ? '+' : ''}}{{todayProfit}}
        </view>
      </view>
      <view class="summary-item">
        <view class="summary-label">本月收益</view>
        <view class="summary-value {{monthProfit > 0 ? 'up' : monthProfit < 0 ? 'down' : ''}}">
          {{monthProfit > 0 ? '+' : ''}}{{monthProfit}}
        </view>
      </view>
      <view class="summary-item">
        <view class="summary-label">本年收益</view>
        <view class="summary-value {{yearProfit > 0 ? 'up' : yearProfit < 0 ? 'down' : ''}}">
          {{yearProfit > 0 ? '+' : ''}}{{yearProfit}}
        </view>
      </view>
    </view>

    <view class="chart-card">
      <view class="chart-title">收益走势</view>
      <canvas canvas-id="profitCanvas" id="profitCanvas" style="width:100%;height:400rpx"></canvas>
    </view>

    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'day' ? 'active' : ''}}" bind:tap="onTabTap" data-tab="day">日</view>
      <view class="tab-item {{activeTab === 'month' ? 'active' : ''}}" bind:tap="onTabTap" data-tab="month">月</view>
      <view class="tab-item {{activeTab === 'year' ? 'active' : ''}}" bind:tap="onTabTap" data-tab="year">年</view>
      <view class="tab-toggle" bind:tap="onToggleMode">
        {{displayMode === 'amount' ? '金额' : '收益率'}}
        <text class="toggle-arrow">▼</text>
      </view>
    </view>

    <view wx:if="{{activeTab === 'day'}}" class="table-card">
      <view class="table-header">
        <view class="th-date">日期</view>
        <view class="th-profit">{{displayMode === 'amount' ? '收益金额' : '收益率'}}</view>
      </view>
      <view wx:for="{{dayData}}" wx:key="date" class="table-row">
        <view class="td-date">{{item.date.slice(5)}}</view>
        <view class="td-profit {{item.profit > 0 ? 'up' : item.profit < 0 ? 'down' : ''}}">
          {{displayMode === 'amount' ? (item.profit > 0 ? '+' : '') + item.profit : (item.profitRate > 0 ? '+' : '') + item.profitRate + '%'}}
        </view>
      </view>
    </view>

    <view wx:if="{{activeTab === 'month'}}" class="table-card">
      <view class="table-header">
        <view class="th-date">日期</view>
        <view class="th-profit">{{displayMode === 'amount' ? '收益金额' : '收益率'}}</view>
      </view>
      <view wx:for="{{monthData}}" wx:key="date" class="table-row">
        <view class="td-date">{{item.date.slice(5)}}</view>
        <view class="td-profit {{item.profit > 0 ? 'up' : item.profit < 0 ? 'down' : ''}}">
          {{displayMode === 'amount' ? (item.profit > 0 ? '+' : '') + item.profit : (item.profitRate > 0 ? '+' : '') + item.profitRate + '%'}}
        </view>
      </view>
    </view>

    <view wx:if="{{activeTab === 'year'}}" class="table-card">
      <view class="table-header">
        <view class="th-date">月份</view>
        <view class="th-profit">{{displayMode === 'amount' ? '收益金额' : '收益率'}}</view>
      </view>
      <view wx:for="{{yearData}}" wx:key="date" class="table-row">
        <view class="td-date">{{item.date}}</view>
        <view class="td-profit {{item.profit > 0 ? 'up' : item.profit < 0 ? 'down' : ''}}">
          {{displayMode === 'amount' ? (item.profit > 0 ? '+' : '') + item.profit : (item.profitRate > 0 ? '+' : '') + item.profitRate + '%'}}
        </view>
      </view>
    </view>
  </view>
</view>
