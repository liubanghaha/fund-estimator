<view class="page-wrap {{theme === 'red' ? 'theme-red' : 'theme-blue'}}">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-text">分析中...</view>

  <!-- 内容 -->
  <view wx:else>
    <!-- 1. 持仓健康分 -->
    <view wx:if="{{healthScore}}" class="card">
      <view class="card-title">📊 持仓健康分</view>
      <view class="health-main">
        <view class="health-ring">
          <view class="health-ring-inner">
            <text class="health-score">{{healthScore.score}}</text>
            <text class="health-label">健康分</text>
          </view>
          <view class="health-ring-arc" style="background:conic-gradient(#4CAF50 0deg {{healthScore.score * 3.6}}deg, #EEE {{healthScore.score * 3.6}}deg 360deg)"></view>
        </view>
        <view class="health-right">
          <view class="health-grade {{healthScore.grade === '优秀' ? 'up' : healthScore.grade === '较差' ? 'down' : ''}}">{{healthScore.grade}}</view>
          <view class="health-detail">估值{{healthScore.avgNormPE != null ? (healthScore.avgNormPE < 0.7 ? '低估' : healthScore.avgNormPE < 1.3 ? '正常' : '高估') : '--'}} · 最大行业 {{healthScore.maxIndustry}}%</view>
          <view class="health-bars">
            <view class="health-bar-item"><text class="hb-label">估值温度</text><view class="hb-track"><view class="hb-fill" style="width:{{healthScore.tempScore}}%"></view></view><text class="hb-val">{{healthScore.tempScore}}</text></view>
            <view class="health-bar-item"><text class="hb-label">行业分散</text><view class="hb-track"><view class="hb-fill" style="width:{{healthScore.concScore}}%"></view></view><text class="hb-val">{{healthScore.concScore}}</text></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 2. 持仓穿透 -->
    <view wx:if="{{assetAllocation && assetAllocation.items.length > 0}}" class="card">
      <view class="card-title">🏭 行业穿透</view>
      <view wx:for="{{assetAllocation.items}}" wx:key="industry" class="asset-row">
        <text class="asset-name">{{item.industry}}</text>
        <text class="asset-pct">{{item.percent}}%</text>
        <view class="asset-bar"><view class="asset-fill" style="width:{{item.percent * 2}}rpx"></view></view>
      </view>
      <view wx:if="{{assetAllocation.warning}}" class="asset-warning">⚠️ {{assetAllocation.warning}}</view>
    </view>

    <!-- 3. 持仓重合度 -->
    <view wx:if="{{pairs.length > 0}}" class="card">
      <view class="card-title">🔗 持仓重合度
        <text class="card-desc">（本季度前十大持仓对比）</text>
      </view>

      <!-- 重合股票 -->
      <view wx:if="{{sharedStocks.length > 0}}" class="shared-section">
        <view class="card-subtitle">重合持仓股</view>
        <view wx:for="{{sharedStocks}}" wx:key="stockCode" class="shared-item" bind:tap="onToggleSharedStock" data-index="{{index}}">
          <view class="shared-left">
            <text class="shared-name">{{item.stockName}}（{{item.stockCode}}）</text>
            <text class="shared-arrow {{item._open ? 'open' : ''}}">{{item._open ? '▼' : '▶'}}</text>
          </view>
          <text class="shared-count">{{item.fundCount}}只基金持有</text>
        </view>
        <view wx:if="{{item._open}}" wx:for="{{sharedStocks}}" wx:key="stockCode" wx:for-item="stock" wx:for-index="idx" hidden="{{!stock._open}}" class="shared-funds">
          <view wx:for="{{stock.funds}}" wx:key="fundCode" wx:for-item="f" class="shared-fund-item">
            <text class="sfi-name">{{f.fundName || f.fundCode}}</text>
            <text class="sfi-ratio">{{f.ratio}}%</text>
          </view>
        </view>
      </view>

      <!-- 基金对重合 -->
      <view class="card-subtitle" style="margin-top:{{sharedStocks.length > 0 ? '20rpx' : '0'}}">基金重合度</view>
      <view wx:for="{{pairs}}" wx:key="key" class="corr-item">
        <view class="corr-names">
          <text class="corr-name">{{item.nameA}}</text>
          <text class="corr-vs">↔</text>
          <text class="corr-name">{{item.nameB}}</text>
        </view>
        <view class="corr-right">
          <view class="corr-bar-track">
            <view class="corr-bar-fill {{item.overlapCount >= 3 ? 'high' : item.overlapCount >= 1 ? 'mid' : 'low'}}" style="width:{{item.overlapCount * 10}}%"></view>
          </view>
          <text class="corr-val {{item.overlapCount >= 3 ? 'high' : item.overlapCount >= 1 ? 'mid' : 'low'}}">{{item.overlapCount}}只</text>
        </view>
      </view>
    </view>

    <view wx:if="{{!loadError && !healthScore && (!assetAllocation || !assetAllocation.items) && pairs.length === 0}}" class="empty">暂无数据</view>
    <view wx:if="{{loadError}}" class="empty">加载失败，请稍后重试</view>
  </view>
</view>
