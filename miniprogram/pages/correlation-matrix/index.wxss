.page-wrap{min-height:100vh;background:#F5F5F5;padding-bottom:40rpx}
.header{padding:32rpx 24rpx 16rpx}
.header-title{font-size:32rpx;font-weight:700;color:#333}
.header-desc{margin-top:8rpx;font-size:22rpx;color:#BBB}
.loading-text{text-align:center;padding:80rpx 0;font-size:28rpx;color:#BBB}
.empty{text-align:center;padding:80rpx 0;font-size:26rpx;color:#CCC}
.matrix-wrap{padding:0 24rpx}
.matrix-scroll{width:100%}
.matrix{display:inline-block;min-width:100%}
.m-row{display:flex}
.m-head{border-bottom:2rpx solid #EEE}
.m-cell{width:120rpx;height:80rpx;display:flex;align-items:center;justify-content:center;border-bottom:1rpx solid #F5F5F5;border-right:1rpx solid #F5F5F5;flex-shrink:0}
.m-label{width:120rpx;font-size:24rpx;color:#666;font-weight:500;background:#FAFAFA;position:sticky;left:0;z-index:1;border-right:2rpx solid #EEE}
.m-head-name{font-size:22rpx;color:#999;transform:scale(.85);white-space:nowrap}
.m-val{font-size:28rpx;font-weight:600}
.m-val.self{color:#333}
.m-val.high{color:#E4393C}
.m-val.mid{color:#FF9800}
.m-val.low{color:#4CAF50}
.warnings{margin-top:24rpx}
.warn-item{padding:16rpx 20rpx;background:#FFF8E1;border-radius:8rpx;font-size:24rpx;color:#B8860B;margin-bottom:12rpx;line-height:1.5}
.legend{display:flex;justify-content:center;gap:24rpx;margin-top:32rpx;padding:16rpx 24rpx}
.legend-item{display:flex;align-items:center;gap:6rpx;font-size:20rpx;color:#999}
.legend-dot{width:16rpx;height:16rpx;border-radius:4rpx}
.legend-dot.high{background:#E4393C}
.legend-dot.mid{background:#FF9800}
.legend-dot.low{background:#4CAF50}
