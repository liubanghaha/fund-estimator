<view class="container">
  <!-- 截图导入（仅新建模式，未选图时） -->
  <view wx:if="{{!isEdit && !screenshotUrl && !ocrLoading}}" class="import-bar">
    <view class="import-btn" bind:tap="onImportScreenshot">
      <text class="import-icon">📷</text>
      <text class="import-text">截图导入</text>
      <text class="import-hint">自动识别持仓信息，可手动修正</text>
    </view>
  </view>

  <!-- 识别中 -->
  <view wx:if="{{ocrLoading}}" class="import-loading">
    <text>正在识别截图...</text>
  </view>

  <!-- 截图预览（识别完成后对照） -->
  <view wx:if="{{screenshotUrl && !ocrLoading}}" class="screenshot-preview">
    <image class="preview-img" src="{{screenshotUrl}}" mode="widthFix" />
    <view class="preview-actions">
      <text class="preview-tip">截图已加载，可对照填写</text>
      <text class="preview-remove" bind:tap="onRemoveScreenshot">移除</text>
    </view>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">基金代码</text>
      <input class="input" value="{{fundCode}}" bind:input="onFundCodeInput" placeholder="输入基金代码" disabled="{{isEdit}}"/>
    </view>
    <view class="form-item">
      <text class="label">基金名称</text>
      <input class="input" value="{{fundName}}" bind:input="onFundNameInput" placeholder="输入或自动获取" disabled="{{isEdit}}"/>
    </view>
    <view class="form-item">
      <text class="label">买入净值</text>
      <input class="input" type="digit" value="{{buyPrice}}" bind:input="onBuyPriceInput" placeholder="0.00"/>
    </view>
    <view class="form-item">
      <text class="label">持有份额</text>
      <input class="input" type="digit" value="{{shares}}" bind:input="onSharesInput" placeholder="0.00"/>
    </view>
    <view class="form-item">
      <text class="label">买入金额</text>
      <input class="input" type="digit" value="{{buyAmount}}" bind:input="onBuyAmountInput" placeholder="0.00"/>
    </view>
    <view class="form-item">
      <text class="label">买入日期</text>
      <picker mode="date" value="{{buyDate}}" bind:change="onDateChange">
        <view class="picker-value">{{buyDate || '请选择日期'}}</view>
      </picker>
    </view>
  </view>
  <button class="submit-btn" bind:tap="onSubmit">{{isEdit ? '更新持仓' : '保存持仓'}}</button>
  <button wx:if="{{isEdit}}" class="delete-btn" bind:tap="onDelete">删除此持仓</button>
</view>

<!-- 多选弹窗 -->
<view wx:if="{{showPicker}}" class="picker-overlay" bind:tap="onPickerCancel">
  <view class="picker-panel" catch:tap="noop">
    <view class="picker-header">
      <text class="picker-title">识别到 {{ocrHoldings.length}} 个基金</text>
      <text class="picker-select-all" bind:tap="onSelectAll">{{allSelected ? '取消全选' : '全选'}}</text>
    </view>
    <scroll-view class="picker-list" scroll-y>
      <view wx:for="{{ocrHoldings}}" wx:key="index" class="picker-item" bind:tap="onToggleItem" data-index="{{index}}">
        <view class="picker-checkbox {{item._checked ? 'checked' : ''}}">
          <text wx:if="{{item._checked}}">✓</text>
        </view>
        <view class="picker-info">
          <text class="picker-fname">{{item.fundName || '未知基金'}}</text>
          <text wx:if="{{item.buyAmount}}" class="picker-amount">¥{{item.buyAmount}}</text>
        </view>
      </view>
    </scroll-view>
    <view class="picker-footer">
      <button class="picker-cancel" bind:tap="onPickerCancel">取消</button>
      <button class="picker-confirm" bind:tap="onPickerConfirm">确认添加 ({{selectedCount}})</button>
    </view>
  </view>
</view>
