<view wx:if="{{!mode}}" class="loading-inline"><text class="loading-text">加载中...</text></view>
<view wx:else class="container {{theme === 'red' ? 'theme-red' : 'theme-blue'}}">

  <!-- ========== 截图导入模式 ========== -->
  <block wx:if="{{mode === 'screenshot'}}">


      <!-- 未选图 -->
      <view wx:if="{{!screenshotUrl && !ocrLoading}}" class="import-bar">
        <text class="import-desc">上传持仓截图，自动识别代码和金额</text>
        <text class="demo-sub-tip">识别结果可能有偏差，请核对后保存</text>
        <view class="import-btn" bind:tap="onImportScreenshot">
          <text class="import-icon">📷</text>
          <text class="import-text">截图导入</text>
          <text class="import-hint">自动识别持仓信息，可手动修正</text>
        </view>
      </view>


    <!-- 截图预览 -->
    <view wx:if="{{screenshotUrl && !ocrLoading}}" class="screenshot-preview">
      <image class="preview-img" src="{{screenshotUrl}}" mode="widthFix" />
      <view class="preview-actions">
        <text class="preview-tip">截图已加载</text>
        <text class="preview-remove" bind:tap="onRemoveScreenshot">移除</text>
      </view>
    </view>


    <!-- 基金卡片列表 -->
    <view wx:if="{{ocrFunds.length > 0}}" class="fund-cards">
      <view class="cards-header">
        <text class="cards-title">识别到 {{ocrFunds.length}} 条记录</text>
      </view>

      <view wx:for="{{ocrFunds}}" wx:key="index" class="fund-card {{item._saved ? 'saved' : ''}}">
        <view class="card-left">
          <input wx:if="{{!item._saved}}" class="card-code-input" value="{{item.fundCode}}" placeholder="输入代码" bind:input="onOcrCodeInput" data-index="{{index}}"/>
          <text wx:else class="card-code">{{item.fundCode || '--'}}</text>
          <text class="card-name">{{item.fundName}}</text>
          <view class="card-nums">
            <text wx:if="{{item.marketValue != null && item.marketValue !== ''}}" class="card-mv">持有金额 ¥{{item.marketValue}}</text>
            <text wx:if="{{item.holdingReturn != null && item.holdingReturn !== ''}}" class="card-hr">持有收益 {{item.holdingReturn}}</text>
          </view>
        </view>
        <view class="card-right">
          <text wx:if="{{item._saved}}" class="card-done">已保存</text>
          <text wx:else class="card-edit" bind:tap="onEditFund" data-index="{{index}}">编辑</text>
        </view>
      </view>

      <view class="cards-footer">
        <button wx:if="{{unsavedCount > 0}}" class="save-all-btn" bind:tap="onSaveAll" disabled="{{saving}}">
          全部保存 ({{unsavedCount}})
        </button>
        <text wx:else class="cards-footer-hint">全部已保存，可在首页查看持仓</text>
      </view>
    </view>
  </block>

  <!-- ========== 手动填写模式 ========== -->
  <block wx:if="{{mode === 'manual'}}">
    <view class="form">
      <view wx:if="{{_editIdx < 0}}" class="form-item">
        <text class="label">代码</text>
        <input class="input" value="{{fundCode}}" bind:input="onFundCodeInput"
               placeholder="输入代码" disabled="{{isEdit}}"/>
      </view>
      <view wx:if="{{_editIdx < 0}}" class="form-item">
        <text class="label">名称</text>
        <input class="input" value="{{fundName}}" bind:input="onFundNameInput"
               placeholder="输入或自动获取" disabled="{{isEdit}}"/>
      </view>
      <view class="form-item">
        <text class="label">持有金额</text>
        <input class="input" type="digit" value="{{marketValue}}"
               bind:input="onMarketValueInput" placeholder="0.00"/>
      </view>
      <view class="form-item">
        <text class="label">持有收益</text>
        <view class="signed-input">
          <view class="sign-toggle {{holdingSign < 0 ? 'minus' : ''}}" bind:tap="onToggleHoldingSign">{{holdingSign < 0 ? '−' : '+'}}</view>
          <input class="input signed-val" type="digit" value="{{holdingReturnAbs}}"
                 bind:input="onHoldingReturnInput" placeholder="0.00"/>
        </view>
      </view>
      <view wx:if="{{isEdit}}" class="form-item">
        <text class="label">加减持仓</text>
        <view class="signed-input">
          <view class="sign-toggle {{adjustSign < 0 ? 'minus' : ''}}" bind:tap="onToggleAdjustSign">{{adjustSign < 0 ? '−' : '+'}}</view>
          <input class="input signed-val" type="digit" value="{{adjustAmountAbs}}"
                 bind:input="onAdjustInput" bind:focus="onAdjustFocus" placeholder="0.00"/>
        </view>
      </view>
      <view wx:if="{{isEdit && showAdjustPicker}}" class="form-item">
        <text class="label">交易日期</text>
        <picker mode="date" value="{{adjustDate}}" bind:change="onAdjustDateChange">
          <view class="picker-value">{{adjustDate || '点击选择日期'}}</view>
        </picker>
      </view>
      <view wx:if="{{isEdit && showAdjustPicker}}" class="form-item">
        <text class="label">备注</text>
        <input class="input" value="{{adjustNote}}" bind:input="onAdjustNoteInput"
               placeholder="选填：操作理由" maxlength="100"/>
      </view>
      <view class="form-item">
        <text class="label">买入日期</text>
        <picker mode="date" value="{{buyDate}}" bind:change="onDateChange">
          <view class="picker-value">{{buyDate || '请选择日期'}}</view>
        </picker>
      </view>
      <view wx:if="{{_editIdx < 0}}" class="form-item">
        <text class="label">所属分组</text>
        <picker mode="selector" range="{{groupPickerRange}}" value="{{groupPickerIndex}}" bind:change="onGroupChange">
          <view class="picker-value">{{selectedGroup || '未分组（点击选择）'}}</view>
        </picker>
      </view>
    </view>

    <view wx:if="{{isEdit}}" class="edit-actions">
      <view class="action-row">
        <button class="action-btn update-btn" bind:tap="onSubmit">更新持仓</button>
        <button class="action-btn delete-btn" bind:tap="onDelete">删除持仓</button>
      </view>
    </view>
    <button wx:else class="submit-btn" bind:tap="onSubmit">保存持仓</button>
  </block>

</view>
