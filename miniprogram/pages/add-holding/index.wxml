<view class="container {{theme === 'red' ? 'theme-red' : 'theme-blue'}}">
  <!-- 顶部模式切换 -->
  <view class="mode-tabs">
    <view class="mode-tab {{mode === 'manual' ? 'active' : ''}}" bind:tap="switchMode" data-mode="manual">📝 手动录入</view>
    <view class="mode-tab {{mode === 'ocr' ? 'active' : ''}}" bind:tap="switchMode" data-mode="ocr">📷 截图导入</view>
  </view>

  <!-- ========== 手动模式 ========== -->
  <view wx:if="{{mode === 'manual'}}">
    <view class="form-title">{{isEdit ? '编辑记录' : '添加记录'}}</view>

    <view class="form-group">
      <view class="form-item">
        <text class="form-label">产品代码</text>
        <input class="form-input" value="{{fundCode}}" bindinput="onInput" data-field="fundCode" placeholder="输入6位产品代码"/>
      </view>
      <view class="form-item">
        <text class="form-label">产品名称</text>
        <input class="form-input" value="{{fundName}}" bindinput="onInput" data-field="fundName" placeholder="输入产品名称"/>
      </view>
      <view class="form-item">
        <text class="form-label">持有份额</text>
        <input class="form-input" value="{{shares}}" bindinput="onInput" data-field="shares" type="digit" placeholder="购买份额"/>
      </view>
      <view class="form-item">
        <text class="form-label">投入成本</text>
        <input class="form-input" value="{{cost}}" bindinput="onInput" data-field="cost" type="digit" placeholder="购买金额（元）"/>
      </view>
      <view class="form-item">
        <text class="form-label">购买日期</text>
        <input class="form-input" value="{{buyDate}}" bindinput="onInput" data-field="buyDate" placeholder="如 2024-01-15（选填）"/>
      </view>
      <view class="form-item" bind:tap="onToggleGroupPicker">
        <text class="form-label">分组</text>
        <view class="form-picker">{{group || '未分组'}} <text class="picker-arrow">▼</text></view>
      </view>
    </view>

    <!-- 分组选择 -->
    <view wx:if="{{showGroupPicker}}" class="group-picker">
      <view class="gp-item {{group === '' ? 'active' : ''}}" bind:tap="onSelectGroup" data-group="">未分组</view>
      <view wx:for="{{groups}}" wx:key="*this" class="gp-item {{group === item ? 'active' : ''}}" bind:tap="onSelectGroup" data-group="{{item}}">{{item}}</view>
    </view>

    <!-- 按钮 -->
    <view class="form-btns">
      <button wx:if="{{isEdit}}" class="btn-del" bind:tap="onDelete">删除记录</button>
      <button class="btn-save" bind:tap="onSave">{{isEdit ? '保存修改' : '添加记录'}}</button>
    </view>

    <!-- 加减仓（编辑模式才显示） -->
    <view wx:if="{{isEdit}}" class="trade-section">
      <view class="section-title" bind:tap="onToggleTrade">
        <text>交易记录</text>
        <text class="section-arrow">{{showTrade ? '▲' : '▼'}}</text>
      </view>

      <view wx:if="{{showTrade}}" class="trade-form">
        <view class="trade-type-row">
          <view class="trade-type {{tradeType === 'buy' ? 'active buy' : ''}}" bind:tap="onTradeTypeChange" data-type="buy">买入</view>
          <view class="trade-type {{tradeType === 'sell' ? 'active sell' : ''}}" bind:tap="onTradeTypeChange" data-type="sell">卖出</view>
        </view>
        <view class="form-item">
          <text class="form-label">{{tradeType === 'buy' ? '买入' : '卖出'}}金额</text>
          <input class="form-input" value="{{tradeAmount}}" bindinput="onTradeInput" data-field="tradeAmount" type="digit" placeholder="金额（元）"/>
        </view>
        <view class="form-item">
          <text class="form-label">{{tradeType === 'buy' ? '买入' : '卖出'}}价格</text>
          <input class="form-input" value="{{tradePrice}}" bindinput="onTradeInput" data-field="tradePrice" type="digit" placeholder="单位价格"/>
        </view>
        <view class="form-item">
          <text class="form-label">日期</text>
          <input class="form-input" value="{{tradeDate}}" bindinput="onTradeInput" data-field="tradeDate" placeholder="如 2024-01-15"/>
        </view>
        <button class="btn-save small" bind:tap="onSaveTrade">记录交易</button>
      </view>

      <!-- 已有交易记录 -->
      <view wx:if="{{transactions.length > 0}}" class="tx-list">
        <view wx:for="{{transactions}}" wx:key="_id" class="tx-item">
          <view class="tx-type {{item.type === 'buy' ? 'buy' : 'sell'}}">{{item.type === 'buy' ? '买入' : '卖出'}}</view>
          <view class="tx-info">
            <view class="tx-amount">{{item.amount}} 元 / {{item.shares}} 份</view>
            <view class="tx-date">{{item.date || ''}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== OCR 模式 ========== -->
  <view wx:if="{{mode === 'ocr'}}">
    <view wx:if="{{!ocrLoading && ocrFunds.length === 0}}" class="ocr-empty">
      <view class="ocr-icon">📷</view>
      <view class="ocr-desc">上传理财平台记录截图</view>
      <view class="ocr-hint">识别结果可能有偏差，请核对后保存</view>
      <view class="ocr-hint-sub"></view>
      <button class="btn-save" bind:tap="onChooseImage">选择截图</button>
    </view>

    <view wx:if="{{ocrLoading}}" class="ocr-loading">
      <view class="loading-icon">🔍</view>
      <view class="loading-text">识别中...</view>
    </view>

    <view wx:if="{{ocrFunds.length > 0}}" class="ocr-result">
      <view class="ocr-result-title">识别到 {{ocrFunds.length}} 条记录</view>
      <view wx:for="{{ocrFunds}}" wx:key="index" class="ocr-item {{item._checked ? 'checked' : ''}}" bind:tap="toggleOcrItem" data-index="{{index}}">
        <view class="ocr-checkbox {{item._checked ? 'on' : ''}}">{{item._checked ? '✓' : ''}}</view>
        <view class="ocr-info">
          <view class="ocr-code">{{item.fundCode}}</view>
          <input class="ocr-name-input" value="{{item.fundName}}" bindinput="onOcrNameChange" data-index="{{index}}" placeholder="产品名称"/>
          <view wx:if="{{item.shares}}" class="ocr-shares">{{item.shares}} 份</view>
        </view>
      </view>
      <button class="btn-save" bind:tap="onOcrSave" loading="{{ocrSaving}}">确认添加（已选 {{ocrCheckedCount}} 只）</button>
      <view class="ocr-retry" bind:tap="onChooseImage">重新选择</view>
    </view>
  </view>
</view>
