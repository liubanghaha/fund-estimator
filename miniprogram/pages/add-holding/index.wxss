.container{padding:24rpx}

/* 截图导入入口 */
.import-bar{display:flex;flex-direction:column;align-items:center;padding-top:80rpx}
.import-desc{font-size:26rpx;color:#666;text-align:center;margin-bottom:12rpx}
.import-btn{background:linear-gradient(135deg,#E8F5E9,#C8E6C9);border:2rpx dashed #4CAF50;border-radius:16rpx;padding:28rpx 20rpx;text-align:center;width:calc(100% - 80rpx)}
.import-icon{font-size:44rpx;display:block;margin-bottom:8rpx}
.import-text{font-size:30rpx;color:#2E7D32;font-weight:600;display:block;margin-bottom:6rpx}
.import-hint{font-size:22rpx;color:#81C784;display:block}

.demo-sub-tip{font-size:22rpx;color:#BBB;text-align:center;display:block;margin-bottom:24rpx}

/* 截图预览 */
.screenshot-preview{margin-bottom:24rpx;background:#FFF;border-radius:20rpx;overflow:hidden;box-shadow:0 2rpx 12rpx rgba(0,0,0,.03)}
.preview-img{width:100%;display:block}
.preview-actions{display:flex;justify-content:space-between;align-items:center;padding:20rpx 28rpx}
.preview-tip{font-size:24rpx;color:#999}
.preview-remove{font-size:24rpx;color:#E4393C}

/* ========== 基金卡片列表 ========== */
.cards-header{margin-bottom:16rpx}
.cards-title{font-size:28rpx;font-weight:600;color:#1A1A1A}

.fund-card{display:flex;align-items:center;justify-content:space-between;background:#FFF;border-radius:12rpx;margin-bottom:12rpx;padding:24rpx 24rpx;box-shadow:0 1rpx 6rpx rgba(0,0,0,.04)}
.fund-card.saved{opacity:.45}

.card-left{flex:1;min-width:0}
.card-code{font-size:20rpx;color:#999;display:block}
.card-name{font-size:28rpx;font-weight:600;color:#1A1A1A;margin:4rpx 0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.card-nums{display:flex;gap:20rpx;margin-top:6rpx}
.card-mv{font-size:22rpx;color:#666}
.card-hr{font-size:22rpx;color:#E4393C}

.card-right{flex-shrink:0;margin-left:16rpx;display:flex;flex-direction:column;gap:10rpx;align-items:flex-end}
.card-save{font-size:22rpx;color:#FFF;background:var(--primary);padding:8rpx 24rpx;border-radius:28rpx}
.card-edit{font-size:22rpx;color:var(--primary);padding:8rpx 24rpx;border:1rpx solid var(--primary);border-radius:28rpx}
.card-done{font-size:24rpx;color:#4CAF50}

.cards-footer{text-align:center;padding:24rpx 0;font-size:24rpx;color:#CCC}
.save-all-btn{width:100%;height:88rpx;line-height:88rpx;font-size:30rpx;color:#FFF;background:var(--primary-gradient);border-radius:44rpx;padding:0}
.cards-footer-hint{font-size:24rpx;color:#4CAF50}

/* ========== 手动填写 ========== */
.form{background:#FFF;border-radius:20rpx;padding:0 32rpx;margin-bottom:32rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.03)}
.form-item{display:flex;align-items:center;justify-content:space-between;padding:30rpx 0;border-bottom:1rpx solid #F5F5F5}
.form-item:last-child{border-bottom:none}
.label{font-size:28rpx;color:#333;width:160rpx;font-weight:500}
.input{flex:1;text-align:right;font-size:28rpx;color:#1A1A1A}
.picker-value{font-size:28rpx;color:#999;text-align:right;width:100%}

/* 正负号切换 */
.signed-input{display:flex;align-items:center;gap:12rpx;flex:1;justify-content:flex-end}
.sign-toggle{width:28rpx;height:28rpx;line-height:28rpx;text-align:center;font-size:18rpx;font-weight:600;color:#FFF;background:var(--primary);border-radius:14rpx;flex-shrink:0}
.sign-toggle.minus{background:#2E8B57}
.signed-val{flex:1}

.submit-btn{width:100%;height:92rpx;line-height:92rpx;font-size:32rpx;color:#FFF;background:var(--primary-gradient);border-radius:46rpx;text-align:center;padding:0;margin-bottom:24rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.15)}

/* 编辑模式 */
.edit-actions{margin-bottom:24rpx}
.action-row{display:flex;gap:16rpx;margin-bottom:16rpx}
.action-btn{flex:1;height:84rpx;line-height:84rpx;font-size:28rpx;border-radius:42rpx;text-align:center;padding:0}
.sync-buy,.sync-sell{background:#FFF;color:#333;border:2rpx solid #E5E5E5}
.update-btn{background:var(--primary);color:#FFF}
.delete-btn{background:#E4393C;color:#FFF}
.adjust-btn{background:#2E8B57;color:#FFF}
