.search-bar{display:flex;align-items:center;padding:20rpx 24rpx;background:#FFF}
.search-input{flex:1;height:72rpx;padding:0 24rpx;background:#F5F5F5;border-radius:36rpx;font-size:28rpx}
.search-btn{margin-left:16rpx;width:120rpx;height:72rpx;line-height:72rpx;font-size:28rpx;background:#E4393C;color:#FFF;border-radius:36rpx;text-align:center;padding:0}
.loading,.error,.empty{text-align:center;padding:60rpx 0;font-size:28rpx;color:#999}
.error{color:#E4393C}
.result-item{display:flex;align-items:center;justify-content:space-between;padding:28rpx 32rpx;background:#FFF;border-bottom:1rpx solid #EEE}
.item-name{font-size:30rpx;color:#333}
.item-code{font-size:24rpx;color:#999;display:block;margin-top:8rpx}
.item-arrow{font-size:28rpx;color:#CCC}
