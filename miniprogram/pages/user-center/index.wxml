<view class="container {{theme === 'red' ? 'theme-red' : 'theme-blue'}}">
  <view class="user-header">
    <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}" />
    <view class="avatar-placeholder" wx:else>🌿</view>
    <view class="nickname">{{isLoggedIn ? nickName || '微信用户' : '点击登录'}}</view>
    <view wx:if="{{!isLoggedIn}}" class="login-tip" bind:tap="onLogin">登录后可管理数据</view>
  </view>

  <!-- 公众号关注 -->
  <view class="menu-list">
    <view class="oa-guide">
      <view class="oa-text">📢 关注公众号，解锁更多功能</view>
      <view class="oa-hint">搜索「你的公众号名称」关注</view>
      <official-account></official-account>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bind:tap="onFeedback">
      <text>意见反馈</text><text class="arrow">{{showFeedback ? '∨' : '>'}}</text>
    </view>
    <view class="menu-item" bind:tap="onShowVersion">
      <text>关于</text><text class="arrow">></text>
    </view>
    <view class="menu-item" bind:tap="onToggleTheme">
      <text>主题色</text><text class="arrow">{{theme === 'red' ? '红白' : '蓝白'}}</text>
    </view>
  </view>

  <!-- 反馈表单 -->
  <view wx:if="{{showFeedback}}" class="feedback-form">
    <view class="fb-section">
      <view class="fb-label">反馈类型</view>
      <view class="fb-type-row">
        <view class="fb-type-item {{feedbackType === 'suggestion' ? 'active' : ''}}" bind:tap="onTypeTap" data-type="suggestion">💡 功能建议</view>
        <view class="fb-type-item {{feedbackType === 'bug' ? 'active' : ''}}" bind:tap="onTypeTap" data-type="bug">🐛 问题反馈</view>
        <view class="fb-type-item {{feedbackType === 'other' ? 'active' : ''}}" bind:tap="onTypeTap" data-type="other">💬 其他</view>
      </view>
    </view>
    <view class="fb-section">
      <view class="fb-label">详细描述</view>
      <textarea class="fb-textarea" value="{{feedbackText}}" placeholder="请详细描述你的建议或遇到的问题…" maxlength="500" auto-height bind:input="onFeedbackInput"/>
      <view class="fb-count">{{feedbackText.length}}/500</view>
    </view>
    <view class="fb-section">
      <view class="fb-label">截图（选填，最多3张）</view>
      <view class="fb-images">
        <block wx:for="{{feedbackImages}}" wx:key="index">
          <view class="fb-img-item">
            <image class="fb-img" src="{{item}}" mode="aspectFill" />
            <view class="fb-img-del" bind:tap="onRemoveImage" data-index="{{index}}">×</view>
          </view>
        </block>
        <view wx:if="{{feedbackImages.length < 3}}" class="fb-img-add" bind:tap="onAddImage">
          <text class="fb-img-add-icon">+</text>
        </view>
      </view>
    </view>
    <view class="fb-actions">
      <button class="fb-cancel" bind:tap="onFeedback">取消</button>
      <button class="fb-submit" bind:tap="onSubmitFeedback" loading="{{feedbackSubmitting}}" disabled="{{feedbackSubmitting}}">提交反馈</button>
    </view>
  </view>

</view>
