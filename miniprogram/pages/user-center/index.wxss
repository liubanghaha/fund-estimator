.container{padding:24rpx;min-height:100vh;background:#F5F5F5}

/* 用户区 */
.user-header{display:flex;flex-direction:column;align-items:center;padding:60rpx 0 40rpx;background:#FFF;border-radius:16rpx;margin-bottom:24rpx}
.avatar{width:120rpx;height:120rpx;border-radius:50%}
.avatar-placeholder{font-size:80rpx;margin-bottom:16rpx}
.nickname{font-size:32rpx;font-weight:600;color:#333;margin-top:16rpx}
.login-tip{font-size:24rpx;color:var(--primary);margin-top:8rpx}

/* 菜单 */
.menu-list{background:#FFF;border-radius:16rpx;overflow:hidden;margin-bottom:24rpx}
.menu-item{display:flex;align-items:center;justify-content:space-between;padding:28rpx 24rpx;font-size:28rpx;color:#333;border-bottom:1rpx solid #F5F5F5}
.menu-item:last-child{border-bottom:none}
.menu-item.highlight{color:var(--primary);font-weight:500}
.menu-left{display:flex;align-items:center;gap:12rpx}
.menu-icon{font-size:32rpx}
.arrow{font-size:24rpx;color:#CCC}

/* 公众号引导 */
.oa-guide{padding:24rpx;display:flex;flex-direction:column;align-items:center}
.oa-text{font-size:26rpx;color:#666;margin-bottom:6rpx}
.oa-hint{font-size:22rpx;color:#BBB;margin-bottom:12rpx}

/* 反馈 */
.feedback-form{background:#FFF;border-radius:16rpx;padding:24rpx;margin-bottom:24rpx}
.fb-section{margin-bottom:20rpx}
.fb-label{font-size:26rpx;color:#666;margin-bottom:10rpx}
.fb-type-row{display:flex;gap:16rpx}
.fb-type-item{padding:10rpx 24rpx;font-size:24rpx;color:#666;background:#F5F5F5;border-radius:20rpx}
.fb-type-item.active{background:var(--primary);color:#FFF}
.fb-textarea{width:100%;min-height:120rpx;padding:16rpx;background:#F9F9F9;border-radius:8rpx;font-size:26rpx;box-sizing:border-box}
.fb-count{text-align:right;font-size:22rpx;color:#BBB;margin-top:4rpx}
.fb-images{display:flex;flex-wrap:wrap;gap:12rpx}
.fb-img-item{position:relative;width:140rpx;height:140rpx}
.fb-img{width:100%;height:100%;border-radius:8rpx}
.fb-img-del{position:absolute;top:-8rpx;right:-8rpx;width:36rpx;height:36rpx;background:#E4393C;color:#FFF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24rpx}
.fb-img-add{width:140rpx;height:140rpx;border:2rpx dashed #DDD;border-radius:8rpx;display:flex;align-items:center;justify-content:center}
.fb-img-add-icon{font-size:48rpx;color:#CCC}
.fb-actions{display:flex;gap:16rpx}
.fb-cancel{flex:1;height:80rpx;line-height:80rpx;background:#F5F5F5;color:#666;border-radius:12rpx;font-size:28rpx;text-align:center;padding:0}
.fb-submit{flex:1;height:80rpx;line-height:80rpx;background:var(--primary);color:#FFF;border-radius:12rpx;font-size:28rpx;text-align:center;padding:0}
