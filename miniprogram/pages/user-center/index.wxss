.container{padding:24rpx}
.user-header{display:flex;flex-direction:column;align-items:center;padding:60rpx 0 40rpx;background:#FFF;border-radius:16rpx;margin-bottom:24rpx}
.avatar{width:120rpx;height:120rpx;border-radius:50%;margin-bottom:20rpx;background:#F0F0F0}
.avatar-placeholder{font-size:80rpx;margin-bottom:20rpx;width:120rpx;height:120rpx;line-height:120rpx;text-align:center;border-radius:50%;background:#F0F0F0}
.nickname{font-size:32rpx;color:#333}
.menu-list{background:#FFF;border-radius:16rpx;margin-bottom:24rpx}
.menu-item{display:flex;justify-content:space-between;align-items:center;padding:32rpx;font-size:30rpx;border-bottom:1rpx solid #F0F0F0}
.menu-item:last-child{border-bottom:none}
.arrow{color:#CCC}
.login-tip{text-align:center;padding:32rpx;font-size:28rpx;color:#07C160;background:#FFF;border-radius:16rpx}
.logout-btn{text-align:center;padding:32rpx;font-size:28rpx;color:#CCC;background:#FFF;border-radius:16rpx}
