<view class="container">
  <view class="fund-info">
    <text class="fi-name">{{fundName}}</text>
    <text class="fi-code">{{fundCode}}</text>
  </view>

  <view class="form-item">
    <text class="label">{{tradeType === 'buy' ? '加仓' : '减仓'}}金额</text>
    <input class="amount-input" type="digit" value="{{amount}}" bindinput="onAmountInput" placeholder="输入金额"/>
    <text class="unit">元</text>
  </view>
  <view class="fee-item">
    <text class="fee-label">手续费</text>
    <input class="fee-input" type="digit" value="{{fee}}" bindinput="onFeeInput" placeholder="0.00"/>
    <text class="fee-unit">元</text>
  </view>

  <view class="section-title">交易时间</view>
  <view class="picker-wrap">
    <view class="picker-mask-top"></view>
    <view class="picker-mask-bottom"></view>
    <picker-view class="date-picker" value="{{[selectedDateIdx]}}" bindchange="onDateChange" indicator-style="height:50px;">
      <picker-view-column>
        <view wx:for="{{dateList}}" wx:key="date" class="picker-item">{{item.label}}</view>
      </picker-view-column>
    </picker-view>
    <view class="picker-center-line"></view>
  </view>

  <view class="pm-toggle" bind:tap="onToggle3PM">
    <text class="pm-label">下午三点后交易（算次日）</text>
    <view class="pm-switch {{isAfter3PM ? 'on' : ''}}">
      <view class="pm-knob"></view>
    </view>
  </view>

  <view wx:if="{{selectedDate && amount}}" class="preview-card">
    <text class="preview-label">确认信息</text>
    <view class="preview-row">
      <text class="preview-left">{{tradeType === 'buy' ? '加仓' : '减仓'}}</text>
      <text class="preview-mid">{{netAmount}} 元</text>
      <text class="preview-right">{{isAfter3PM ? '次日' : ''}}{{selectedDate}}</text>
    </view>
  </view>

  <button class="submit-btn" bind:tap="onSubmit">确认</button>
</view>
