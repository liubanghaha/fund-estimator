.page{min-height:100vh;background:#F5F5F5;overflow-x:hidden}

.loading-wrap{display:flex;align-items:center;justify-content:center;padding-top:200rpx}
.loading-text{font-size:28rpx;color:#999}

/* 骨架屏 */
.skeleton-wrap{padding:16rpx 24rpx}
.sk-item{height:100rpx;border-radius:16rpx;margin-bottom:12rpx}

.empty-wrap{display:flex;flex-direction:column;align-items:center;padding-top:200rpx}
.empty-icon{font-size:80rpx;margin-bottom:24rpx}
.empty-text{font-size:30rpx;color:#999;margin-bottom:12rpx}
.empty-hint{font-size:24rpx;color:#CCC;margin-bottom:32rpx}
.search-btn,.add-fund-btn{width:280rpx;height:72rpx;line-height:72rpx;font-size:28rpx;color:#FFF;background:#E4393C;border-radius:36rpx;text-align:center;padding:0}
.add-fund-btn{margin-top:16rpx;width:240rpx;font-size:26rpx}

/* 分组标签栏 */
.group-tabs-wrap{padding:16rpx 0 4rpx;background:#FFF}
.group-tabs{display:flex;white-space:nowrap;padding:0 24rpx}
.group-tab{display:inline-block;font-size:28rpx;color:#999;padding:14rpx 32rpx;border-radius:24rpx;background:#F5F5F5;margin-right:14rpx;flex-shrink:0;line-height:1.4}
.group-tab.active{color:#FFF;background:#E4393C;font-weight:500}
.group-tab.dragging{box-shadow:0 4rpx 16rpx rgba(0,0,0,.2);transform:scale(1.08);opacity:.9}
.group-tab-add{width:64rpx;text-align:center;padding:14rpx 0;color:#CCC;font-size:30rpx;font-weight:300}
.update-time{text-align:right;font-size:20rpx;color:#CCC;padding:4rpx 24rpx 0}

/* 搜索栏 */
.search-bar{display:flex;align-items:center;margin:12rpx 24rpx;background:#FFF;border-radius:12rpx;padding:0 16rpx;gap:8rpx}
.search-input{flex:1;height:64rpx;font-size:26rpx;min-width:0}
.search-clear{font-size:28rpx;color:#CCC;padding:0 4rpx;flex-shrink:0}
.search-sort-btn{font-size:24rpx;color:#1976D2;padding:6rpx 16rpx;border-radius:14rpx;background:#E3F2FD;flex-shrink:0;white-space:nowrap}
.search-sort-btn-only{font-size:24rpx;color:#1976D2;padding:6rpx 16rpx;border-radius:14rpx;background:#E3F2FD;margin-left:auto}

/* 列表项时间 */
.item-time{font-size:20rpx;color:#CCC;margin-top:2rpx}

/* 列表项上的分组标签 */
.group-tag{display:inline-block;font-size:18rpx;color:#1976D2;background:#E3F2FD;border-radius:4rpx;padding:0 8rpx;margin-left:8rpx;vertical-align:middle;line-height:1.6}

.list{padding:12rpx 24rpx}
.item-wrap{position:relative;overflow:hidden;border-radius:16rpx;margin-bottom:12rpx}
.item{display:flex;justify-content:space-between;align-items:center;background:#FFF;padding:24rpx 24rpx;border-radius:16rpx;position:relative;z-index:1;transition:transform .2s}
.swipe-del-btn{position:absolute;right:0;top:0;bottom:0;width:120rpx;display:flex;align-items:center;justify-content:center;background:#E4393C;color:#FFF;font-size:26rpx;border-radius:0 16rpx 16rpx 0}
.item-left{flex:1;min-width:0}
.item-name{font-size:30rpx;font-weight:500;color:#333;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.item-code{font-size:22rpx;color:#BBB;margin-top:4rpx}
.item-right{text-align:right;flex-shrink:0}
.item-rate{font-size:30rpx;font-weight:600;color:#999}
.item-rate.up{color:#E4393C}
.item-rate.down{color:#2E8B57}
.item-nav{font-size:24rpx;color:#999;margin-top:6rpx}

/* 批量模式 */
.batch-item{padding-left:16rpx}
.item-check{width:40rpx;height:40rpx;border:2rpx solid #CCC;border-radius:20rpx;margin-right:16rpx;display:flex;align-items:center;justify-content:center;font-size:22rpx;color:#FFF;flex-shrink:0}
.item-check.checked{background:#E4393C;border-color:#E4393C}
.batch-bar{display:flex;justify-content:flex-end;align-items:center;gap:16rpx;padding:16rpx 24rpx;background:#FFF;box-shadow:0 -2rpx 12rpx rgba(0,0,0,.04);flex-wrap:wrap}
.batch-time{font-size:22rpx;color:#BBB;margin-right:auto}
.batch-edit-btn{font-size:26rpx;color:#E4393C;padding:8rpx 20rpx}
.batch-select-all{font-size:26rpx;color:#666;padding:8rpx 20rpx}
.batch-move-btn{font-size:26rpx;color:#1976D2;padding:8rpx 28rpx;border-radius:28rpx;background:#E3F2FD}
.batch-delete-btn{font-size:26rpx;color:#FFF;background:#E4393C;padding:8rpx 28rpx;border-radius:28rpx}
.batch-cancel-btn{font-size:26rpx;color:#999;padding:8rpx 20rpx}

/* 涨跌汇总条 */
.summary-bar{display:flex;align-items:center;gap:24rpx;margin:8rpx 24rpx;padding:12rpx 20rpx;background:#FFF;border-radius:10rpx}
.summary-item{font-size:24rpx;color:#999}
.summary-avg{font-weight:600}
.summary-avg.up{color:#E4393C}
.summary-avg.down{color:#2E8B57}
.summary-up{color:#E4393C}
.summary-down{color:#2E8B57}

/* 置顶标识 */
.pin-mark{font-size:24rpx;margin-right:4rpx}

/* 热门基金 */
.hot-wrap{margin-top:48rpx;width:100%}
.hot-title{text-align:center;font-size:24rpx;color:#CCC;margin-bottom:24rpx}
.hot-list{display:flex;flex-wrap:wrap;justify-content:center;gap:16rpx;padding:0 24rpx}
.hot-item{display:flex;flex-direction:column;align-items:center;padding:16rpx 24rpx;background:#FFF;border-radius:12rpx;min-width:180rpx}
.hot-name{font-size:26rpx;color:#333;margin-bottom:4rpx}
.hot-code{font-size:22rpx;color:#BBB}
