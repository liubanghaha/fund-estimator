.page-wrap{min-height:100vh;background:#F5F5F5}

/* 空状态 */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48rpx;min-height:70vh}
.empty-icon{font-size:80rpx;margin-bottom:24rpx}
.empty-title{font-size:32rpx;font-weight:600;color:#333;margin-bottom:12rpx}
.empty-desc{font-size:26rpx;color:#999;text-align:center;line-height:1.6}
.empty-hint{font-size:24rpx;color:#BBB;text-align:center;margin-bottom:24rpx}
.empty-btns{display:flex;flex-direction:column;gap:16rpx;width:100%}
.login-btn{width:100%;height:88rpx;line-height:88rpx;font-size:32rpx;color:#FFF;background:var(--primary);border-radius:44rpx;text-align:center;padding:0}

.container{padding:16rpx 24rpx}

/* 工具栏 */
.toolbar{display:flex;gap:16rpx;margin-bottom:16rpx}
.tool-btn{flex:1;height:72rpx;line-height:72rpx;font-size:26rpx;color:#FFF;background:var(--primary);border-radius:12rpx;text-align:center;padding:0}
.tool-btn.secondary{background:#FFF;color:var(--primary);border:1rpx solid var(--primary);line-height:72rpx}

/* 批量栏 */
.batch-bar{display:flex;align-items:center;justify-content:space-between;padding:16rpx 0;margin-bottom:8rpx}
.batch-cancel{font-size:26rpx;color:var(--primary)}
.batch-title{font-size:28rpx;font-weight:600;color:#333}
.batch-right{display:flex;gap:24rpx}
.batch-link{font-size:26rpx;color:var(--primary)}
.batch-del{font-size:26rpx;color:#E4393C}

/* 分组标签 */
.group-tabs-wrap{margin-bottom:12rpx;background:#FFF;border-radius:12rpx;padding:8rpx 0}
.group-tabs{white-space:nowrap;width:100%;padding:0 20rpx}
.group-tab{display:inline-flex;align-items:center;padding:12rpx 20rpx;margin-right:8rpx;font-size:24rpx;color:#888;background:#F5F5F5;border-radius:24rpx;white-space:nowrap}
.group-tab.active{color:#FFF;background:var(--primary);font-weight:500}
.group-tab-add{width:52rpx;height:52rpx;padding:0;justify-content:center;font-size:28rpx;font-weight:600;color:#BBB;border:1rpx dashed #DDD;background:transparent}

/* 列表 */
.list-section{background:#FFF;border-radius:12rpx;overflow:hidden}
.list-row{display:flex;align-items:center;padding:24rpx 24rpx;border-bottom:1rpx solid #F5F5F5}
.list-row:last-child{border-bottom:none}
.list-row.selected{outline:3rpx solid var(--primary);outline-offset:-3rpx}
.list-info{flex:1;overflow:hidden}
.list-name{font-size:28rpx;font-weight:500;color:#333;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.list-code{font-size:22rpx;color:#999;margin-top:4rpx}
.list-actions{display:flex;gap:16rpx;flex-shrink:0}
.list-btn{font-size:24rpx;color:var(--primary);padding:8rpx 16rpx;background:var(--primary-bg);border-radius:8rpx}
.list-btn.del{color:#E4393C;background:rgba(227,57,60,.08)}
.batch-check{width:36rpx;height:36rpx;border:2rpx solid #CCC;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20rpx;margin-right:16rpx;flex-shrink:0}
.batch-check.checked{background:var(--primary);border-color:var(--primary);color:#FFF}

/* 弹窗 */
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;z-index:1001;background:rgba(0,0,0,.35);display:flex;align-items:center;justify-content:center}
.modal-card{width:560rpx;background:#FFF;border-radius:16rpx;padding:32rpx}
.modal-title{font-size:28rpx;font-weight:600;color:#333;margin-bottom:20rpx}
.form-field{display:flex;align-items:center;margin-bottom:16rpx}
.form-label{width:140rpx;font-size:26rpx;color:#666}
.form-input{flex:1;height:64rpx;border:1rpx solid #E5E5E5;border-radius:8rpx;padding:0 16rpx;font-size:26rpx}
.form-btn{width:100%;height:80rpx;line-height:80rpx;background:var(--primary);color:#FFF;border-radius:44rpx;font-size:28rpx;text-align:center;padding:0;margin-top:8rpx}

.picker-item{padding:24rpx 16rpx;font-size:28rpx;color:#333;border-bottom:1rpx solid #F5F5F5;text-align:center}
.picker-new-btn{text-align:center;padding:20rpx;font-size:28rpx;color:var(--primary);border-top:1rpx solid #F5F5F5}
.picker-close{margin-top:16rpx;text-align:center;background:#F5F5F5;color:#666;border-radius:8rpx;padding:16rpx 0;font-size:26rpx}
