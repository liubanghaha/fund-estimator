<view class="page-wrap {{theme === 'red' ? 'theme-red' : 'theme-blue'}}">
  <!-- 空状态 -->
  <view wx:if="{{loaded && watchlist.length === 0}}" class="empty-state">
    <view class="empty-icon">⭐</view>
    <view class="empty-title">我的关注</view>
    <view class="empty-desc">添加你关注的产品</view>
    <view class="empty-hint">手动输入产品代码和名称即可</view>
    <view class="empty-btns">
      <button class="login-btn" bind:tap="onShowAdd">添加关注</button>
    </view>
  </view>

  <view wx:else class="container">
    <!-- 批量栏 -->
    <view wx:if="{{batchMode}}" class="batch-bar">
      <text class="batch-cancel" bind:tap="onToggleBatch">取消</text>
      <text class="batch-title">已选 {{selectedCount}} 项</text>
      <view class="batch-right">
        <text wx:if="{{!allSelected}}" class="batch-link" bind:tap="onSelectAll">全选</text>
        <text wx:else class="batch-link" bind:tap="onSelectAll">取消全选</text>
        <text class="batch-link" bind:tap="onBatchMoveGroup">移动分组</text>
        <text class="batch-del" bind:tap="onBatchDelete">删除</text>
      </view>
    </view>

    <view wx:else class="toolbar">
      <button class="tool-btn" bind:tap="onShowAdd">+ 添加关注</button>
      <text class="tool-btn secondary" bind:tap="onToggleBatch">批量管理</text>
    </view>

    <!-- 分组标签 -->
    <view class="group-tabs-wrap">
      <scroll-view class="group-tabs" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="group-tab {{activeGroup === 'all' ? 'active' : ''}}" bind:tap="onGroupTap" data-group="all">全部 {{groupCounts.all || 0}}</view>
        <view class="group-tab {{activeGroup === 'ungrouped' ? 'active' : ''}}" bind:tap="onGroupTap" data-group="ungrouped">未分组 {{groupCounts.ungrouped || 0}}</view>
        <block wx:for="{{groups}}" wx:key="*this">
          <view class="group-tab {{activeGroup === item ? 'active' : ''}}" bind:tap="onGroupTap" data-group="{{item}}">{{item}} {{groupCounts[item] || 0}}</view>
        </block>
        <view class="group-tab group-tab-add" bind:tap="onAddGroup">+</view>
      </scroll-view>
    </view>

    <!-- 列表 -->
    <view class="list-section">
      <view wx:for="{{displayList}}" wx:key="_id"
        class="list-row {{batchMode && item._checked ? 'selected' : ''}}">
        <view wx:if="{{batchMode}}" class="batch-check {{item._checked ? 'checked' : ''}}" catch:tap="onToggleSelect" data-index="{{index}}">{{item._checked ? '✓' : ''}}</view>
        <view class="list-info">
          <view class="list-name">{{item.fundName}}</view>
          <view class="list-code">{{item.fundCode}}</view>
        </view>
        <view class="list-actions">
          <text class="list-btn" bind:tap="onMoveGroup" data-code="{{item.fundCode}}">分组</text>
          <text class="list-btn del" bind:tap="onDeleteItem" data-code="{{item.fundCode}}">移除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 添加弹窗 -->
  <view wx:if="{{showAdd}}" class="modal-mask" bind:tap="onCloseAdd">
    <view class="modal-card" catch:tap="">
      <view class="modal-title">添加关注</view>
      <view class="form-field">
        <text class="form-label">产品代码</text>
        <input class="form-input" value="{{addCode}}" bindinput="onAddCodeInput" placeholder="输入6位产品代码" focus/>
      </view>
      <view class="form-field">
        <text class="form-label">产品名称</text>
        <input class="form-input" value="{{addName}}" bindinput="onAddNameInput" placeholder="输入产品名称"/>
      </view>
      <button class="form-btn" bind:tap="onConfirmAdd">确认添加</button>
    </view>
  </view>

  <!-- 分组选择器 -->
  <view wx:if="{{showGroupPicker}}" class="modal-mask" bind:tap="onCloseGroupPicker">
    <view class="modal-card" catch:tap="">
      <view class="modal-title">移动到分组</view>
      <scroll-view scroll-y style="max-height:480rpx;margin:16rpx 0">
        <view wx:for="{{groups}}" wx:key="*this" class="picker-item" bind:tap="onPickGroup" data-group="{{item}}">{{item}}</view>
        <view class="picker-item" bind:tap="onPickGroup" data-group="">📂 未分组</view>
      </scroll-view>
      <view class="picker-new-btn" bind:tap="onPickNewGroup">+ 新建分组</view>
      <view class="picker-close" bind:tap="onCloseGroupPicker">取消</view>
    </view>
  </view>
</view>
