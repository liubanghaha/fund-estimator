<view class="page">
  <view wx:if="{{!loaded}}" class="skeleton-wrap">
    <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="sk-item skeleton"></view>
  </view>

  <view wx:elif="{{watchlist.length === 0}}" class="empty-wrap">
    <view class="empty-icon">⭐</view>
    <view class="empty-text">暂无自选基金</view>
    <view class="empty-hint">在基金详情页点击「加自选」添加自选</view>
    <button class="search-btn" bind:tap="onSearch">去搜索基金</button>
  </view>

  <view wx:else class="list">
    <view wx:for="{{watchlist}}" wx:key="fundCode" class="item {{batchMode ? 'batch-item' : ''}}"
      bind:tap="onTapItem"
      bind:longpress="onLongPressItem"
      data-code="{{item.fundCode}}" data-name="{{item.fundName}}" data-index="{{index}}">
      <view wx:if="{{batchMode}}" class="item-check {{item._checked ? 'checked' : ''}}">
        {{item._checked ? '✓' : ''}}
      </view>
      <view class="item-left">
        <view class="item-name">{{item.fundName}}</view>
        <view class="item-code">{{item.fundCode}}</view>
      </view>
      <view class="item-right">
        <view class="item-rate {{item.estimatedChangeRate > 0 ? 'up' : item.estimatedChangeRate < 0 ? 'down' : ''}}">
          {{item.estimatedChangeRate > 0 ? '+' : ''}}{{item.estimatedChangeRate != null ? item.estimatedChangeRate : '--'}}%
        </view>
        <view class="item-nav">{{item.estimatedNav || item.nav || '--'}}</view>
      </view>
    </view>
  </view>

  <!-- 批量操作栏 -->
  <view wx:if="{{watchlist.length > 0}}" class="batch-bar">
    <text wx:if="{{!batchMode}}" class="batch-edit-btn" bind:tap="onToggleBatch">编辑</text>
    <block wx:else>
      <text class="batch-select-all" bind:tap="onSelectAll">全选</text>
      <text class="batch-delete-btn" bind:tap="onBatchDelete">删除</text>
      <text class="batch-cancel-btn" bind:tap="onToggleBatch">取消</text>
    </block>
  </view>
</view>
