.login-page{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:0 48rpx;box-sizing:border-box}
.login-logo{text-align:center;margin-bottom:60rpx}
.logo-icon{font-size:100rpx;margin-bottom:32rpx}
.logo-title{font-size:40rpx;font-weight:600;color:#333;margin-bottom:16rpx}
.logo-desc{font-size:28rpx;color:#999}
.login-btn{width:100%;height:88rpx;line-height:88rpx;font-size:32rpx;color:#FFF;background:var(--primary-gradient);border-radius:44rpx;text-align:center;padding:0}
.login-tip{margin-top:32rpx;font-size:24rpx;color:#CCC}
