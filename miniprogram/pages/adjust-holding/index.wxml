<view wx:if="{{redirecting}}"></view>
<view wx:else class="container {{theme === 'red' ? 'theme-red' : 'theme-blue'}}">

  <view wx:if="{{!ocrLoading && ocrResults.length === 0}}" class="import-bar">
    <text class="adjust-desc">上传交易记录截图，自动识别金额</text>
    <text class="adjust-sub-tip">识别结果可能有偏差，请核对后保存</text>
    <view class="adjust-import-btn" bind:tap="onImportScreenshot">
      <text class="import-icon">📷</text>
      <text class="import-text">截图导入</text>
      <text class="import-hint">自动识别交易记录</text>
    </view>
  </view>

  <!-- 识别中 -->
  <view wx:if="{{ocrLoading}}" class="loading-overlay">
    <canvas canvas-id="loadCanvas" class="lo-canvas"></canvas>
    <text class="lo-text">{{loadPercent >= 100 ? '识别完成' : '正在识别交易记录'}}</text>
  </view>

  <!-- OCR 识别结果列表 -->
  <view wx:if="{{ocrResults.length > 0 || showManualHint}}" class="results-section">
    <image wx:if="{{screenshotUrl}}" class="result-screenshot" src="{{screenshotUrl}}" mode="widthFix" />
    <view class="results-title">
      <text>{{ocrResults.length > 0 ? '识别到 ' + ocrResults.length + ' 笔交易' : '未识别到交易'}}</text>
      <text wx:if="{{showManualHint}}" class="results-hint">请手动添加或重新截图</text>
    </view>
    <view wx:for="{{ocrResults}}" wx:key="index" class="result-card">
      <view class="rc-del" bind:tap="onRemoveItem" data-index="{{index}}">×</view>
      <view class="rc-main">
        <text class="rc-sign {{item.type === 'buy' ? 'up' : 'down'}}">{{item.type === 'buy' ? '+' : '−'}}</text>
        <view class="rc-info">
          <view class="rc-name-row">
            <text class="rc-name">{{item.fundName || '未知基金'}}</text>
          </view>
          <text class="rc-date">{{item.date || '--'}}{{item.time ? ' ' + item.time : ''}}</text>
        </view>
        <input class="rc-amount-input" type="digit" value="{{item.amount}}" placeholder="金额" bind:input="onAmountInput" data-index="{{index}}"/>
      </view>
    </view>
    <button wx:if="{{ocrResults.length > 0}}" class="submit-all-btn" bind:tap="onConfirmAll">确认</button>
  </view>

  <!-- TODO: 微信审核金融功能，选基金弹窗暂时注释
  <view wx:if="{{showPicker}}" class="picker-mask" bind:tap="onClosePicker">
    <view class="picker-panel" catch:tap="noop">
      <view class="picker-title">选择基金</view>
      <scroll-view scroll-y enhanced scroll-with-animation class="picker-list" style="max-height:40vh">
        <view wx:for="{{holdings}}" wx:key="_id" class="picker-item" bind:tap="onSelectFund" data-index="{{index}}">
          <text>{{item.fundName}}</text>
          <text class="picker-shares">{{item._currentShares}}份</text>
        </view>
      </scroll-view>
    </view>
  </view>
  -->

</view>
