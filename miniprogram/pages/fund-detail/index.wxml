<view class="page {{theme === 'red' ? 'theme-red' : 'theme-blue'}}">
  <view class="page-body">
    <view class="fund-header">
      <view class="header-top">
        <view class="header-info">
          <view class="header-name">{{fundName}}</view>
          <view class="header-code">{{fundCode}}</view>
        </view>
        <view class="follow-btn {{followed ? 'followed' : ''}}" bind:tap="onToggleFollow">
          {{followed ? '已自选' : '+ 加自选'}}
        </view>
      </view>
    </view>

    <scroll-view scroll-y class="detail-scroll" scroll-into-view="{{scrollToTx}}" scroll-with-animation refresher-enabled="{{true}}" refresher-triggered="{{scrollRefreshing}}" bindrefresherrefresh="onScrollRefresh">
    <view wx:if="{{errorMsg}}" class="error-wrap">
      <view class="error-text">{{errorMsg}}</view>
      <button class="retry-btn" bind:tap="fetchAll">重试</button>
    </view>

    <view wx:if="{{loading}}" class="loading-inline">
      <text class="loading-text">加载中...</text>
    </view>

    <block wx:if="{{!loading}}">
    <view wx:if="{{isTrading && estimatedNav}}" class="nav-card primary">
      <view class="nav-top-row">
        <view class="nav-main">
          <view class="nav-label">估算净值<text wx:if="{{isNavUpdated}}" class="nav-updated">✓</text></view>
          <view class="nav-big">{{estimatedNav}}</view>
          <view wx:if="{{nav}}" class="nav-ref">昨日净值 {{nav}}</view>
        </view>
        <view class="nav-change-col">
          <view class="nav-change-label">涨幅估算</view>
          <view class="nav-change {{estimatedChangeRate > 0 ? 'up' : estimatedChangeRate < 0 ? 'down' : ''}}">
            {{estimatedChangeRate > 0 ? '+' : ''}}{{estimatedChangeRate != null ? estimatedChangeRate : '--'}}%
          </view>
          <view class="nav-badge">实时数据</view>
        </view>
      </view>
    </view>

    <view wx:if="{{!isTrading || !estimatedNav}}" class="nav-card primary">
      <view class="nav-top-row">
        <view class="nav-main">
          <view wx:if="{{hasHolding && holdingData}}" class="nav-label">当日收益<text wx:if="{{isNavUpdated}}" class="nav-updated">✓</text></view>
          <view wx:else class="nav-label">单位净值<text wx:if="{{isNavUpdated}}" class="nav-updated">✓</text></view>
          <view wx:if="{{hasHolding && holdingData}}" class="nav-big {{holdingData.todayProfit > 0 ? 'up' : holdingData.todayProfit < 0 ? 'down' : ''}}">{{holdingData.todayProfit > 0 ? '+' : ''}}{{holdingData.todayProfit}}</view>
          <view wx:else class="nav-big">{{actualNav || nav || '--'}}</view>
          <view wx:if="{{actualDate && !(hasHolding && holdingData)}}" class="nav-date">净值日期：{{actualDate}}</view>
        </view>
        <view class="nav-change-col">
          <view class="nav-change-label">当日涨幅</view>
          <view class="nav-change {{displayChangeRate > 0 ? 'up' : displayChangeRate < 0 ? 'down' : ''}}">
            {{displayChangeRate > 0 ? '+' : ''}}{{displayChangeRate != null ? displayChangeRate : '--'}}%
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{riskMetrics || peTemp}}" class="info-card risk-card">
      <view class="section-title">风险指标<text class="risk-period-tip">近一年</text></view>
      <view class="risk-grid">
        <view wx:if="{{riskMetrics}}" class="risk-item"><view class="risk-label">最大回撤</view><view class="risk-value down">{{riskMetrics.maxDrawdown}}%</view></view>
        <view wx:if="{{riskMetrics}}" class="risk-item"><view class="risk-label">年化波动率</view><view class="risk-value">{{riskMetrics.volatility}}%</view></view>
        <view wx:if="{{riskMetrics}}" class="risk-item"><view class="risk-label">夏普比率</view><view class="risk-value {{riskMetrics.sharpe > 1 ? 'up' : ''}}">{{riskMetrics.sharpe}}</view></view>
        <view wx:if="{{peTemp && peTemp.signal !== 'nodata'}}" class="risk-item">
          <view class="risk-label">估值温度<text class="risk-label-note">{{peTemp.normPE}}</text></view>
          <view class="risk-value temp-val {{peTemp.signal === 'low' ? 'temp-low' : peTemp.signal === 'high' ? 'temp-high' : 'temp-mid'}}">{{peTemp.label}}</view>
        </view>
      </view>
    </view>

    <!-- 我的持仓 -->
    <view wx:if="{{hasHolding && holdingData}}" class="my-holding-card">
      <view class="mh-title">我的持仓</view>
      <view class="mh-grid">
        <view class="mh-item">
          <view class="mh-label">持有金额</view>
          <view class="mh-value">{{holdingData.marketValue}}</view>
        </view>
        <view class="mh-item">
          <view class="mh-label">持有份额</view>
          <view class="mh-value">{{holdingData.shares}}</view>
        </view>
        <view class="mh-item">
          <view class="mh-label">买入净值</view>
          <view class="mh-value">{{holdingData.buyPrice}}</view>
        </view>
        <view class="mh-item">
          <view class="mh-label">累计收益</view>
          <view class="mh-value {{holdingData.totalReturn > 0 ? 'up' : holdingData.totalReturn < 0 ? 'down' : ''}}">{{holdingData.totalReturn > 0 ? '+' : ''}}{{holdingData.totalReturn}}</view>
        </view>
        <view class="mh-item">
          <view class="mh-label">累计收益率</view>
          <view class="mh-value {{holdingData.totalReturnRate > 0 ? 'up' : holdingData.totalReturnRate < 0 ? 'down' : ''}}">{{holdingData.totalReturnRate > 0 ? '+' : ''}}{{holdingData.totalReturnRate}}%</view>
        </view>
        <view class="mh-item">
          <view class="mh-label">单位净值</view>
          <view class="mh-value">{{actualNav || nav || '--'}}</view>
        </view>
        <view wx:if="{{quarterNet != null && quarterNet !== 0}}" class="mh-item">
          <view class="mh-label">近3月变动</view>
          <view class="mh-value {{quarterNet > 0 ? 'up' : 'down'}}">{{quarterNet > 0 ? '+' : ''}}{{quarterNet}}</view>
        </view>
      </view>
    </view>

    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'trend' ? 'active' : ''}}" bind:tap="onTabTap" data-tab="trend">走势</view>
      <view class="tab-item {{activeTab === 'holdings' ? 'active' : ''}}" bind:tap="onTabTap" data-tab="holdings">持仓</view>
      <view class="tab-item {{activeTab === 'profile' ? 'active' : ''}}" bind:tap="onTabTap" data-tab="profile">档案</view>
    </view>

    <view hidden="{{activeTab !== 'trend'}}">
      <view wx:if="{{navHistory.length > 1}}" class="chart-card">
        <view class="section-title">收益走势</view>
        <view class="period-tabs">
          <view class="period-item {{chartPeriod === '1M' ? 'active' : ''}}" bind:tap="onChartPeriod" data-period="1M">近一月</view>
          <view class="period-item {{chartPeriod === '3M' ? 'active' : ''}}" bind:tap="onChartPeriod" data-period="3M">近三月</view>
          <view class="period-item {{chartPeriod === '6M' ? 'active' : ''}}" bind:tap="onChartPeriod" data-period="6M">近半年</view>
          <view class="period-item {{chartPeriod === '1Y' ? 'active' : ''}}" bind:tap="onChartPeriod" data-period="1Y">近一年</view>
          <view class="period-item {{chartPeriod === '3Y' ? 'active' : ''}}" bind:tap="onChartPeriod" data-period="3Y">近三年</view>
        </view>
        <canvas type="2d" id="navCanvas" style="width:100%;height:{{canvasHRpx}}rpx" bindtouchstart="onChartTouch" bindtouchmove="onChartTouch" bindtouchend="onChartTouch"></canvas>
      </view>
      <view class="info-card"><view class="section-title">收益表现</view>
        <view class="metrics-grid">
          <view class="metric-item"><view class="metric-label">近1周</view><view class="metric-value {{weekReturn > 0 ? 'up' : weekReturn < 0 ? 'down' : ''}}">{{weekReturn != null ? (weekReturn > 0 ? '+' : '') + weekReturn + '%' : '--'}}</view></view>
          <view class="metric-item"><view class="metric-label">近1月</view><view class="metric-value {{monthReturn > 0 ? 'up' : monthReturn < 0 ? 'down' : ''}}">{{monthReturn != null ? (monthReturn > 0 ? '+' : '') + monthReturn + '%' : '--'}}</view></view>
          <view class="metric-item"><view class="metric-label">近3月</view><view class="metric-value {{threeMonthReturn > 0 ? 'up' : threeMonthReturn < 0 ? 'down' : ''}}">{{threeMonthReturn != null ? (threeMonthReturn > 0 ? '+' : '') + threeMonthReturn + '%' : '--'}}</view></view>
          <view class="metric-item"><view class="metric-label">近6月</view><view class="metric-value {{sixMonthReturn > 0 ? 'up' : sixMonthReturn < 0 ? 'down' : ''}}">{{sixMonthReturn != null ? (sixMonthReturn > 0 ? '+' : '') + sixMonthReturn + '%' : '--'}}</view></view>
          <view class="metric-item"><view class="metric-label">近1年</view><view class="metric-value {{yearReturn > 0 ? 'up' : yearReturn < 0 ? 'down' : ''}}">{{yearReturn != null ? (yearReturn > 0 ? '+' : '') + yearReturn + '%' : '--'}}</view></view>
          <view class="metric-item"><view class="metric-label">近3年</view><view class="metric-value {{threeYearReturn > 0 ? 'up' : threeYearReturn < 0 ? 'down' : ''}}">{{threeYearReturn != null ? (threeYearReturn > 0 ? '+' : '') + threeYearReturn + '%' : '--'}}</view></view>
        </view>
      </view>
      <view wx:if="{{navHistory.length > 0}}" class="info-card">
        <view class="section-title">历史净值</view>
        <view wx:for="{{navHistory}}" wx:key="date" wx:if="{{index < 10 || showAllHistory}}" class="history-row">
          <view class="h-date">{{item.date}}</view>
          <view class="h-nav">{{item.nav}}</view>
          <view class="h-change {{item.changeRate > 0 ? 'up' : item.changeRate < 0 ? 'down' : ''}}">{{item.changeRate > 0 ? '+' : ''}}{{item.changeRate}}%</view>
        </view>
        <view wx:if="{{navHistory.length > 10 && !showAllHistory}}" class="show-more" bind:tap="onShowMore">查看更多 (共{{navHistory.length}}条)</view>
        <view wx:if="{{showAllHistory}}" class="show-more" bind:tap="onShowLess">收起</view>
      </view>
    </view>

    <view wx:if="{{activeTab === 'holdings'}}">
      <view wx:if="{{holdings.length > 0}}" class="info-card">
        <view class="section-title">前十大持仓<text wx:if="{{quarterLabel}}" class="quarter-label" style="float:right;font-size:22rpx;color:#BBB;font-weight:400">{{quarterLabel}}</text></view>
        <view class="hold-header">
          <text class="hold-h-name">名称</text>
          <text class="hold-h-change">今日涨跌</text>
          <text class="hold-h-ratio-chg">调仓动向</text>
          <text class="hold-h-ratio">占比</text>
        </view>
        <view wx:for="{{holdings}}" wx:key="rank" class="hold-row">
          <view class="hold-rank">{{item.rank}}</view>
          <view class="hold-name">{{item.stockName}}<text wx:if="{{item.isHK}}" class="hk-tag">H</text></view>
          <view class="hold-change {{item.stockChangeRate > 0 ? 'up' : item.stockChangeRate < 0 ? 'down' : ''}}">
            {{item.stockChangeRate != null ? (item.stockChangeRate > 0 ? '+' : '') + item.stockChangeRate + '%' : '--'}}
          </view>
          <view class="hold-ratio-change">
            <text wx:if="{{item.changeType === 'new'}}" class="change-tag new">🆕新增</text>
            <text wx:elif="{{item.changeType === 'up'}}" class="change-tag up">📈+{{item.ratioChange}}%</text>
            <text wx:elif="{{item.changeType === 'down'}}" class="change-tag down">📉{{item.ratioChange}}%</text>
            <text wx:else>--</text>
          </view>
          <view class="hold-ratio">{{item.navRatio || '--'}}</view>
        </view>
        <!-- 退出的持仓 -->
        <view wx:if="{{exited && exited.length > 0}}" style="margin-top:16rpx">
          <view class="exited-toggle" bind:tap="onToggleExited">
            <text>上季度退出 ({{exited.length}})</text>
            <text class="exited-arrow {{showExited ? 'open' : ''}}">{{showExited ? '▼' : '▶'}}</text>
          </view>
          <view wx:if="{{showExited}}">
            <view wx:for="{{exited}}" wx:key="stockCode" class="hold-row" style="opacity:.5">
              <view class="hold-rank">-</view>
              <view class="hold-name">{{item.stockName}}</view>
              <view class="hold-change">--</view>
              <view class="hold-ratio-change"><text class="change-tag exit">🚫退出</text></view>
              <view class="hold-ratio">--</view>
            </view>
          </view>
        </view>
      </view>
      <view wx:else class="info-card"><view class="empty-text">暂无持仓数据</view></view>
    </view>

    <view wx:if="{{activeTab === 'profile'}}">
      <view wx:if="{{profileLoading}}" class="loading-compact">
        <text class="loading-text">加载中...</text>
      </view>
      <block wx:elif="{{profileLoaded}}">
      <view wx:if="{{manager && manager.name}}" class="info-card">
        <view class="section-title">基金经理</view>
        <view class="manager-row">
          <view class="manager-avatar">{{manager.name[0]}}</view>
          <view class="manager-info">
            <view class="manager-name">{{manager.name}}</view>
            <view class="manager-detail">任职 {{manager.tenureDays}}天</view>
            <view wx:if="{{manager.tenureReturn}}" class="manager-return {{manager.tenureReturn > 0 ? 'up' : manager.tenureReturn < 0 ? 'down' : ''}}">任职回报 {{manager.tenureReturn > 0 ? '+' : ''}}{{manager.tenureReturn}}%</view>
          </view>
        </view>
      </view>
      <view wx:if="{{profile}}" class="info-card">
        <view class="section-title">基金档案</view>
        <view class="profile-grid">
          <view class="profile-item"><view class="profile-label">基金类型</view><view class="profile-value">{{profile.fundType || '--'}}</view></view>
          <view class="profile-item"><view class="profile-label">成立日期</view><view class="profile-value">{{profile.establishDate || '--'}}</view></view>
          <view class="profile-item"><view class="profile-label">基金规模</view><view class="profile-value">{{profile.fundSizeText}}</view></view>
          <view class="profile-item"><view class="profile-label">风险等级</view><view class="profile-value">{{profile.riskText}}</view></view>
          <view wx:if="{{profile.company}}" class="profile-item full">
            <view class="profile-label">基金公司</view>
            <view class="profile-value">{{profile.company}}</view>
          </view>
        </view>
      </view>
      <view wx:if="{{profile && profile.mgmtFee}}" class="fee-card">
        <view class="fee-header" bind:tap="onToggleFee">
          <view>
            <text class="fee-title">💰 费用黑洞</text>
            <text class="fee-subtitle">年费率 {{totalFeeRate}}</text>
          </view>
          <text class="fee-arrow {{showFee ? 'open' : ''}}">{{showFee ? '▼' : '▶'}}</text>
        </view>
        <view wx:if="{{showFee}}" class="fee-body">
          <view class="fee-note">假设投资¥100,000，年化收益8%，费率差复利侵蚀：</view>
          <view class="fee-table">
            <view class="fee-row fee-row-head">
              <text class="fee-col-label"></text>
              <text class="fee-col">5年后</text>
              <text class="fee-col">10年后</text>
              <text class="fee-col">20年后</text>
            </view>
            <view class="fee-row">
              <text class="fee-col-label">本基金</text>
              <text class="fee-col">¥{{feeData.yr5.withFee}}</text>
              <text class="fee-col">¥{{feeData.yr10.withFee}}</text>
              <text class="fee-col">¥{{feeData.yr20.withFee}}</text>
            </view>
            <view class="fee-row">
              <text class="fee-col-label">零费率</text>
              <text class="fee-col">¥{{feeData.yr5.noFee}}</text>
              <text class="fee-col">¥{{feeData.yr10.noFee}}</text>
              <text class="fee-col">¥{{feeData.yr20.noFee}}</text>
            </view>
            <view class="fee-row fee-row-lost">
              <text class="fee-col-label">被吞</text>
              <text class="fee-col">¥{{feeData.yr5.lost}} ({{feeData.yr5.pct}}%)</text>
              <text class="fee-col">¥{{feeData.yr10.lost}} ({{feeData.yr10.pct}}%)</text>
              <text class="fee-col">¥{{feeData.yr20.lost}} ({{feeData.yr20.pct}}%)</text>
            </view>
          </view>
        </view>
      </view>
      </block>
      <!-- 基金换手率 -->
      <view wx:if="{{turnoverRates.length > 0}}" class="fee-card">
        <view class="fee-header" bind:tap="onToggleTurnover">
          <view>
            <text class="fee-title">🔄 基金换手率</text>
            <text class="fee-subtitle">衡量基金投资组合变化频率</text>
          </view>
          <text class="fee-arrow {{showTurnover ? 'open' : ''}}">{{showTurnover ? '▼' : '▶'}}</text>
        </view>
        <view wx:if="{{showTurnover}}" class="fee-body">
          <view class="turnover-table">
            <view class="turnover-row turnover-head">
              <text class="turnover-cell">报告期</text>
              <text class="turnover-cell" style="text-align:right">换手率</text>
            </view>
            <view wx:for="{{turnoverRates}}" wx:key="date" class="turnover-row">
              <text class="turnover-cell">{{item.date}}</text>
              <text class="turnover-cell turnover-value {{item.rate > 200 ? 'high' : item.rate < 100 ? 'low' : ''}}" style="text-align:right">{{item.rate}}%</text>
            </view>
          </view>
          <view class="turnover-note">
            <view class="turnover-desc">{{'换手率反映基金经理的交易频率。换手率越高，产生的佣金及冲击成本越高，这些费用直接从基金资产中扣除，侵蚀长期收益。换手率<100%通常代表买入持有策略，成本较低；>200%则交易较为活跃。'}}</view>
            <view class="turnover-formula">换手率 = 买卖金额 / (期初+期末净资产)，半/年报披露后更新，来源：天天基金</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{showTransactions}}" class="tx-list-card" id="txSection">
      <view class="section-title">交易记录</view>
      <view wx:if="{{transactionList.length === 0}}" class="empty-text">暂无交易记录</view>
      <view wx:if="{{transactionList.length > 0}}" class="tx-row tx-header">
        <text class="tx-type">类型</text>
        <text class="tx-shares">份额</text>
        <text class="tx-price">净值</text>
        <text class="tx-amount">金额</text>
        <text class="tx-date">日期</text>
      </view>
      <view wx:for="{{transactionList}}" wx:key="_id" class="tx-item">
        <view class="tx-row">
          <text class="tx-type {{item.type === 'buy' ? 'up' : 'down'}}">{{item.type === 'buy' ? '买入' : '卖出'}}</text>
          <text class="tx-shares">{{item.shares > 0 ? item.shares + '份' : '--'}}</text>
          <text class="tx-price">{{item.price > 0 ? item.price + '元' : '--'}}</text>
          <text class="tx-amount">{{item.amount || '--'}}元</text>
          <text class="tx-date">{{item.date}}</text>
        </view>
        <view wx:if="{{item.note}}" class="tx-note-row">💬 {{item.note}}</view>
      </view>
    </view>
    </block>
    </scroll-view>

    <!-- 定投回测 -->
    <view class="dca-section">
      <view class="dca-header" bind:tap="onToggleDCA">
        <view>
          <text class="dca-title">📈 定投模拟</text>
          <text class="dca-subtitle">基于历史净值模拟，过往收益不代表未来</text>
        </view>
        <text class="dca-arrow {{showDCA ? 'open' : ''}}">{{showDCA ? '▼' : '▶'}}</text>
      </view>
      <view wx:if="{{showDCA}}" class="dca-body">
        <view class="dca-form">
          <view class="dca-field">
            <text class="dca-label">月投金额</text>
            <input class="dca-input" type="digit" placeholder="1000" value="{{dcaAmount}}" bindinput="onDCAAmount" />
            <text class="dca-unit">元</text>
          </view>
          <view class="dca-field">
            <text class="dca-label">定投起始</text>
            <picker mode="date" fields="month" value="{{dcaStartDate}}" bindchange="onDCAStartDate">
              <text class="dca-input dca-picker">{{dcaStartDate || '选择年月'}}</text>
            </picker>
          </view>
          <button class="dca-btn" bind:tap="onRunDCA" loading="{{dcaLoading}}">开始模拟</button>
        </view>
        <view wx:if="{{dcaResult}}" class="dca-result">
          <view class="dca-stat-row">
            <view class="dca-stat"><text class="dca-stat-val">{{dcaResult.totalInvested}}</text><text class="dca-stat-label">累计投入(元)</text></view>
            <view class="dca-stat"><text class="dca-stat-val">{{dcaResult.currentValue}}</text><text class="dca-stat-label">当前市值(元)</text></view>
          </view>
          <view class="dca-stat-row">
            <view class="dca-stat"><text class="dca-stat-val {{dcaResult.totalReturn >= 0 ? 'up' : 'down'}}">{{dcaResult.totalReturn >= 0 ? '+' : ''}}{{dcaResult.totalReturn}}</text><text class="dca-stat-label">总收益(元)</text></view>
            <view class="dca-stat"><text class="dca-stat-val {{dcaResult.totalReturn >= 0 ? 'up' : 'down'}}">{{dcaResult.totalReturn >= 0 ? '+' : ''}}{{dcaResult.returnRate}}%</text><text class="dca-stat-label">总收益率</text></view>
          </view>
          <view class="dca-stat-row">
            <view class="dca-stat"><text class="dca-stat-val {{dcaResult.totalReturn >= 0 ? 'up' : 'down'}}">{{dcaResult.totalReturn >= 0 ? '+' : ''}}{{dcaResult.annualizedReturn}}%</text><text class="dca-stat-label">年化收益率</text></view>
            <view class="dca-stat"><text class="dca-stat-val">{{dcaResult.months}}</text><text class="dca-stat-label">定投月数</text></view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-bar">
      <button class="btn-add" bind:tap="onAddHolding">
        <text class="btn-icon">{{hasHolding ? '✏️' : '➕'}}</text>
        <text>{{hasHolding ? '修改持仓' : '添加持仓'}}</text>
      </button>
      <button class="btn-compare" bind:tap="onCompare">
        <text class="btn-icon">📊</text>
        <text>对比</text>
      </button>
      <button wx:if="{{hasHolding}}" class="btn-txn" bind:tap="onRefresh">
        <text class="btn-icon">📋</text>
        <text>{{showTransactions ? '隐藏记录' : '交易记录'}}</text>
      </button>
      <button wx:else class="btn-txn" bind:tap="onImportScreenshot">
        <text class="btn-icon">📷</text>
        <text>截图导入</text>
      </button>
    </view>
    <view class="bottom-safe"></view>
  </view>
</view>
