.page{min-height:100vh;background:#F5F5F5}
.page-body{display:flex;flex-direction:column;height:100vh;overflow:hidden}
.detail-scroll{flex:1;overflow-y:auto}

/* 骨架屏 */
.skeleton-wrap{padding:24rpx}
.sk-header{padding:32rpx;margin-bottom:16rpx}
.sk-title{width:360rpx;height:40rpx;margin-bottom:12rpx}
.sk-code{width:160rpx;height:28rpx}
.sk-nav-card{height:180rpx;border-radius:20rpx;margin-bottom:16rpx}
.sk-tabs{height:88rpx;border-radius:20rpx;margin-bottom:16rpx}
.sk-content{height:400rpx;border-radius:20rpx}
.error-wrap{display:flex;flex-direction:column;align-items:center;padding-top:200rpx}
.error-text{font-size:28rpx;color:#E4393C;margin-bottom:32rpx}
.retry-btn{width:200rpx;height:64rpx;line-height:64rpx;font-size:26rpx;color:#E4393C;background:#FFF;border:1rpx solid #E4393C;border-radius:32rpx;text-align:center;padding:0}

.fund-header{background:#FFF;padding:32rpx 32rpx 24rpx}
.header-top{display:flex;justify-content:space-between;align-items:flex-start}
.header-info{flex:1}
.header-name{font-size:36rpx;font-weight:600;color:#1A1A1A;margin-bottom:10rpx}
.header-code{font-size:26rpx;color:#999}
.follow-btn{flex-shrink:0;padding:10rpx 24rpx;font-size:26rpx;color:var(--primary);border:1rpx solid var(--primary);border-radius:32rpx;margin-top:4rpx}
.follow-btn.followed{color:#999;border-color:#CCC}

.nav-card{background:#FFF;margin:0 24rpx 16rpx;border-radius:20rpx;padding:32rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.04)}
.nav-card.primary{border-left:6rpx solid var(--primary)}

/* H5 入口卡片 */
.h5-entry-card{background:linear-gradient(135deg,#e3f2fd,#bbdefb);margin:0 24rpx 16rpx;border-radius:20rpx;padding:28rpx 32rpx;display:flex;align-items:center;justify-content:space-between;border:1rpx solid #90caf9}
.h5-entry-left{flex:1}
.h5-entry-title{font-size:28rpx;font-weight:600;color:#1565c0;margin-bottom:6rpx}
.h5-entry-desc{font-size:22rpx;color:#1976D2;opacity:.8}
.h5-entry-arrow{font-size:36rpx;color:#1976D2;font-weight:300}
.nav-top-row{display:flex;justify-content:space-between;align-items:flex-start}
.nav-main{flex:1}
.nav-label{font-size:24rpx;color:#999;margin-bottom:10rpx}
.nav-updated{font-size:14rpx;color:#FFF;background:var(--primary);border-radius:50%;width:22rpx;height:22rpx;line-height:22rpx;text-align:center;display:inline-block;margin-left:8rpx;vertical-align:middle}
.nav-big{font-size:52rpx;font-weight:700;color:#1A1A1A;margin-bottom:6rpx}
.nav-big.up{color:#E4393C}
.nav-big.down{color:#2E8B57}
.nav-ref{font-size:22rpx;color:#BBB}
.nav-date{font-size:22rpx;color:#BBB}

.nav-change-col{text-align:right}
.nav-change-label{font-size:24rpx;color:#999;margin-bottom:10rpx}
.nav-change{font-size:52rpx;font-weight:700;color:#999}
.nav-change.up{color:#E4393C}
.nav-change.down{color:#2E8B57}
.nav-badge{display:inline-block;font-size:20rpx;color:#E4393C;background:rgba(228,57,60,.08);padding:4rpx 12rpx;border-radius:8rpx;margin-top:8rpx}

/* 暂无持仓 */
.no-holding-card{text-align:center;padding:48rpx 32rpx;margin:24rpx;background:#FFF;border-radius:14rpx}
.nh-title{font-size:30rpx;font-weight:600;color:#333;margin-bottom:12rpx}
.nh-desc{font-size:24rpx;color:#999;margin-bottom:28rpx}
.nh-import-btn{width:360rpx;height:80rpx;line-height:80rpx;font-size:28rpx;color:#FFF;background:var(--primary-gradient);border-radius:40rpx;text-align:center;padding:0}

/* 我的持仓 */
.my-holding-card{background:#FFF;margin:0 24rpx 16rpx;border-radius:20rpx;padding:28rpx 32rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.04)}
.mh-title{font-size:26rpx;font-weight:600;color:#333;margin-bottom:20rpx}
.mh-grid{display:flex;flex-wrap:wrap}
.mh-item{width:50%;margin-bottom:24rpx}
.mh-label{font-size:22rpx;color:#999;margin-bottom:8rpx}
.mh-value{font-size:30rpx;font-weight:600;color:#1A1A1A}
.mh-value.up{color:#E4393C}
.mh-value.down{color:#2E8B57}

.tab-bar{display:flex;background:#FFF;margin:16rpx 24rpx 0;border-radius:20rpx;overflow:hidden}
.tab-item{flex:1;text-align:center;padding:24rpx 0;font-size:28rpx;color:#999}
.tab-item.active{color:var(--primary);font-weight:600;border-bottom:4rpx solid var(--primary)}

.chart-card{background:#FFF;margin:0 24rpx;border-radius:0 0 20rpx 20rpx;padding:20rpx}
.period-tabs{display:flex;justify-content:center;gap:12rpx;margin-bottom:16rpx}
.period-item{padding:8rpx 24rpx;font-size:24rpx;color:#999;border-radius:20rpx;background:#F5F5F5}
.period-item.active{color:#FFF;background:var(--primary)}
.nav-canvas{width:680rpx;height:360rpx;display:block;margin:0 auto}

.info-card{background:#FFF;margin:16rpx 24rpx;border-radius:20rpx;padding:28rpx 32rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.04)}
.section-title{font-size:28rpx;font-weight:600;color:#1A1A1A;margin-bottom:20rpx}

.metrics-grid{display:flex;flex-wrap:wrap}
.metric-item{width:33.33%;padding:16rpx 0;text-align:center}
.metric-label{font-size:24rpx;color:#999;margin-bottom:8rpx}
.metric-value{font-size:28rpx;font-weight:500;color:#333}
.metric-value.up{color:#E4393C}
.metric-value.down{color:#2E8B57}
.metric-value.muted{color:#CCC}

.manager-row{display:flex;align-items:flex-start;gap:20rpx}
.manager-avatar{width:72rpx;height:72rpx;border-radius:36rpx;background:var(--primary-gradient);color:#FFF;font-size:32rpx;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.manager-info{flex:1;min-width:0}
.manager-name{font-size:28rpx;font-weight:600;color:#1A1A1A;margin-bottom:4rpx}
.manager-detail{font-size:22rpx;color:#999;margin-bottom:4rpx}
.manager-return{font-size:24rpx;font-weight:500}
.manager-return.up{color:#E4393C}
.manager-return.down{color:#2E8B57}

.hold-row{display:flex;align-items:center;justify-content:space-between;padding:20rpx 0;border-bottom:1rpx solid #F5F5F5}
.hold-row:last-child{border-bottom:none}
.hold-rank{width:40rpx;height:40rpx;line-height:40rpx;text-align:center;font-size:22rpx;color:#FFF;background:#BBB;border-radius:8rpx;flex-shrink:0}
.hold-row:nth-child(1) .hold-rank{background:#E4393C}
.hold-row:nth-child(2) .hold-rank{background:#FF6B3C}
.hold-row:nth-child(3) .hold-rank{background:#FF8C3C}
.hold-header{display:flex;align-items:baseline;padding:12rpx 0 8rpx 0;border-bottom:1rpx solid #EEE;margin-bottom:4rpx}
.hold-h-name{flex:1;font-size:22rpx;color:#BBB;margin-left:56rpx}
.hold-h-change{width:120rpx;text-align:right;font-size:22rpx;color:#BBB}
.hold-h-ratio-chg{width:120rpx;text-align:right;font-size:22rpx;color:#BBB}
.hold-h-ratio{width:100rpx;text-align:right;font-size:22rpx;color:#BBB}
.hold-ratio-change{width:120rpx;text-align:right;font-size:24rpx;color:#999}
.change-tag{font-size:22rpx;padding:2rpx 8rpx;border-radius:6rpx;white-space:nowrap}
.change-tag.new{color:#4CAF50;background:rgba(76,175,80,.1)}
.change-tag.up{color:#E4393C;background:rgba(228,57,60,.08)}
.change-tag.down{color:#2E8B57;background:rgba(46,139,87,.08)}
.change-tag.exit{color:#BBB;background:#F5F5F5}

.hold-name{font-size:28rpx;color:#333;margin-left:16rpx;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hk-tag{display:inline-block;font-size:18rpx;color:var(--primary);background:var(--primary-bg);border:1rpx solid var(--primary);border-radius:4rpx;padding:0 6rpx;margin-left:8rpx;vertical-align:middle;font-weight:600;line-height:1.4}
.hold-code{font-size:22rpx;color:#999}
.hold-change{font-size:24rpx;font-weight:500;width:120rpx;text-align:right;flex-shrink:0}
.hold-change.up{color:#E4393C}
.hold-change.down{color:#2E8B57}
.hold-ratio-change{font-size:22rpx;font-weight:400;width:120rpx;text-align:right;flex-shrink:0}
.hold-ratio{font-size:24rpx;font-weight:600;width:100rpx;text-align:right;flex-shrink:0}

.exited-toggle{display:flex;justify-content:space-between;align-items:center;font-size:24rpx;color:#999;padding:10rpx 0}
.exited-arrow{font-size:22rpx;color:#BBB;transition:transform .3s}
.exited-arrow.open{transform:rotate(180deg)}

.profile-grid{display:flex;flex-wrap:wrap}
.profile-item{width:50%;padding:16rpx 0;border-bottom:1rpx solid #F5F5F5}
.profile-item:nth-last-child(-n+2){border-bottom:none}
.profile-item.full{width:100%;border-bottom:1rpx solid #F5F5F5}
.profile-item.full:last-child{border-bottom:none}
.profile-label{font-size:24rpx;color:#999;margin-bottom:8rpx}
.profile-value{font-size:28rpx;color:#1A1A1A;font-weight:500}
.empty-text{font-size:26rpx;color:#CCC;text-align:center;padding:40rpx 0}

.risk-grid{display:flex;flex-wrap:wrap}
.risk-item{width:50%;padding:20rpx 0;border-bottom:1rpx solid #F5F5F5}
.risk-item:nth-last-child(-n+2){border-bottom:none}
.risk-item:last-child{border-bottom:none}
.risk-label{font-size:24rpx;color:#999;margin-bottom:8rpx}
.risk-label-note{font-size:20rpx;color:#BBB;margin-left:6rpx}
.risk-period-tip{float:right;font-size:22rpx;color:#BBB;font-weight:400}
.risk-value{font-size:36rpx;font-weight:700;color:#333}
.risk-value.up{color:#E4393C}
.risk-value.down{color:#2E8B57}
.temp-val{display:flex;align-items:center;gap:8rpx;font-size:30rpx}
.temp-val::before{content:"";width:22rpx;height:22rpx;border-radius:50%;flex-shrink:0}
.temp-low{color:#2E8B57}.temp-low::before{background:#2E8B57}
.temp-mid{color:#F59E0B}.temp-mid::before{background:#F59E0B}
.temp-high{color:#E4393C}.temp-high::before{background:#E4393C}
.risk-sub{font-size:20rpx;color:#BBB;margin-top:4rpx}

.fee-card{margin:16rpx 24rpx;background:#FFF;border-radius:12rpx;overflow:hidden;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04)}
.fee-header{display:flex;justify-content:space-between;align-items:center;padding:20rpx 24rpx;border-bottom:1rpx solid #F5F5F5}
.fee-title{font-size:26rpx;font-weight:500;color:#333}
.fee-subtitle{display:block;font-size:20rpx;color:#BBB;margin-top:4rpx}
.fee-arrow{font-size:22rpx;color:#CCC;transition:transform .3s}
.fee-arrow.open{transform:rotate(180deg)}
.fee-body{padding:20rpx 24rpx}
.fee-note{font-size:22rpx;color:#999;margin-bottom:16rpx}
.fee-table{border-radius:8rpx;overflow:hidden;border:1rpx solid #EEE}
.fee-row{display:flex;border-bottom:1rpx solid #F5F5F5}
.fee-row:last-child{border-bottom:none}
.fee-row-head{background:#FAFAFA}
.fee-row-lost{background:#FFF5F5}
.fee-col-label{width:120rpx;font-size:24rpx;color:#666;padding:16rpx 12rpx;text-align:left}
.fee-row-head .fee-col-label{font-size:22rpx;color:#999}
.fee-col{flex:1;font-size:24rpx;color:#333;padding:16rpx 8rpx;text-align:center}
.fee-row-head .fee-col{font-size:22rpx;color:#999}
.fee-row-lost .fee-col{color:#E4393C;font-weight:500}

.history-row{display:flex;align-items:center;justify-content:space-between;padding:16rpx 0;border-bottom:1rpx solid #F5F5F5}
.history-row:last-child{border-bottom:none}
.h-date{font-size:24rpx;color:#999;width:170rpx}
.h-nav{font-size:26rpx;color:#333;flex:1;text-align:center}
.h-change{font-size:24rpx;font-weight:500;width:120rpx;text-align:right;color:#999}
.h-change.up{color:#E4393C}
.h-change.down{color:#2E8B57}
.show-more{text-align:center;padding:24rpx 0 8rpx;font-size:26rpx;color:var(--primary)}

.bottom-bar{display:flex;gap:12rpx;padding:16rpx 20rpx;background:#FFF;box-shadow:0 -2rpx 16rpx rgba(0,0,0,.06);flex-shrink:0}
.btn-add,.btn-compare,.btn-txn{flex:1;height:80rpx;line-height:80rpx;font-size:24rpx;border-radius:40rpx;text-align:center;padding:0;display:flex;align-items:center;justify-content:center;gap:6rpx}
.btn-icon{font-size:28rpx;line-height:1}
.btn-add{background:var(--primary-gradient);color:#FFF;font-weight:500}
.btn-compare{background:#FFF;color:var(--primary);border:2rpx solid var(--primary);font-weight:500}
.btn-txn{background:#FFF;color:var(--primary);border:2rpx solid var(--primary);font-weight:500}
.bottom-safe{height:24rpx;flex-shrink:0}
/* 交易记录 */
.tx-list-card{background:#FFF;border-radius:14rpx;padding:24rpx;margin:20rpx 24rpx}
.tx-row{display:flex;align-items:center;padding:18rpx 0;border-bottom:1rpx solid #F5F5F5;font-size:24rpx}
.tx-row:last-child{border-bottom:none}
.tx-header{border-bottom:2rpx solid #E5E5E5;padding-bottom:14rpx}
.tx-header .tx-type,.tx-header .tx-shares,.tx-header .tx-price,.tx-header .tx-amount,.tx-header .tx-date{font-size:22rpx;color:#999;font-weight:400}
.tx-type{width:80rpx;font-weight:600;flex-shrink:0}
.tx-shares{flex:1;text-align:center;color:#666}
.tx-price{flex:1;text-align:center;color:#666}
.tx-amount{flex:1;text-align:right;font-weight:500;color:#333}
.tx-date{width:160rpx;text-align:right;color:#BBB;font-size:22rpx;flex-shrink:0}
.tx-item{border-bottom:1rpx solid #F5F5F5}
.tx-item:last-child{border-bottom:none}
.tx-item .tx-row{border-bottom:none}
.tx-note-row{font-size:22rpx;color:#999;padding:0 0 14rpx 80rpx;line-height:1.5}

/* 定投回测 */
.dca-section{margin:16rpx 24rpx;background:#FFF;border-radius:12rpx;overflow:hidden;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04)}
.dca-header{display:flex;justify-content:space-between;align-items:center;padding:20rpx 24rpx;border-bottom:1rpx solid #F5F5F5}
.dca-title{font-size:26rpx;font-weight:500;color:#333}
.dca-subtitle{display:block;font-size:20rpx;color:#BBB;margin-top:4rpx}
.dca-arrow{font-size:22rpx;color:#BBB;flex-shrink:0}
.dca-body{padding:20rpx 24rpx}
.dca-field{display:flex;align-items:center;margin-bottom:16rpx}
.dca-label{width:120rpx;font-size:24rpx;color:#666}
.dca-input{flex:1;height:60rpx;border:1rpx solid #E5E5E5;border-radius:8rpx;padding:0 16rpx;font-size:26rpx;text-align:right}
.dca-picker{color:#999;line-height:60rpx}
.dca-unit{margin-left:8rpx;font-size:24rpx;color:#999}
.dca-btn{margin-top:8rpx;background:var(--primary);color:#FFF;border-radius:8rpx;font-size:26rpx;height:72rpx;line-height:72rpx}
.dca-result{margin-top:20rpx;padding-top:20rpx;border-top:1rpx solid #F0F0F0}
.dca-stat-row{display:flex;margin-bottom:12rpx}
.dca-stat{flex:1;text-align:center}
.dca-stat-val{display:block;font-size:30rpx;font-weight:600;color:#333}
.dca-stat-val.up{color:#E4393C}
.dca-stat-val.down{color:#2E8B57}
.dca-stat-label{display:block;font-size:20rpx;color:#BBB;margin-top:4rpx}


/* 基金换手率 */
.turnover-table{padding:0}
.turnover-row{display:flex;justify-content:space-between;padding:14rpx 0;border-bottom:1rpx solid #F5F5F5}
.turnover-row:last-child{border-bottom:none}
.turnover-head{border-bottom:2rpx solid #E5E5E5;padding-bottom:12rpx}
.turnover-head .turnover-cell{font-size:22rpx;color:#999}
.turnover-cell{font-size:26rpx;color:#333}
.turnover-value{font-weight:600}
.turnover-value.high{color:#E4393C}
.turnover-value.low{color:#2E8B57}
.turnover-note{padding:12rpx 0 0;font-size:20rpx;color:#BBB;line-height:1.6}
.turnover-desc{color:#666;margin-bottom:8rpx}
.turnover-formula{font-size:20rpx}
