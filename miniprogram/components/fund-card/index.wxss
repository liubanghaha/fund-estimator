.fund-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  margin: 16rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.fund-name { font-size: 30rpx; font-weight: 500; color: #333; margin-bottom: 8rpx; }
.fund-code { font-size: 24rpx; color: #999; }
.fund-values { text-align: right; }
.nav-value { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 6rpx; }
.change { font-size: 26rpx; color: #999; }
.change.up { color: #E4393C; }
.change.down { color: #2E8B57; }
.change-amount { margin-left: 8rpx; }
