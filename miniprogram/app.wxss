page {
  --color-primary: #E4393C;
  --color-green: #2E8B57;
  --color-bg: #F5F5F5;
  --color-text: #333333;
  --color-text-light: #999999;
  --color-border: #EEEEEE;

  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
}

.container {
  padding: 24rpx;
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}
@keyframes skeleton-pulse {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 统一内联加载 */
.loading-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 48rpx 0;
}
.loading-inline::before {
  content: "";
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #E4393C;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-inline .loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 紧凑内联加载（用于局部刷新） */
.loading-compact {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 0;
}
.loading-compact::before {
  content: "";
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #E0E0E0;
  border-top-color: #E4393C;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}
.loading-compact .loading-text {
  font-size: 24rpx;
  color: #BBB;
}
