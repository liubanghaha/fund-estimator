page {
  --color-green: #2E8B57;
  --color-bg: #F5F5F5;
  --color-text: #333333;
  --color-text-light: #999999;
  --color-border: #EEEEEE;

  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
}

/* 主题色 */
.theme-blue {
  --primary: #1976D2;
  --primary-gradient: linear-gradient(135deg, #1976D2, #42A5F5);
  --primary-bg: rgba(25,118,210,.1);
}
.theme-red {
  --primary: #E4393C;
  --primary-gradient: linear-gradient(135deg, #E4393C, #FF6B6B);
  --primary-bg: rgba(228,57,60,.1);
}

/* 统一内联加载 */
.loading-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 48rpx 0;
}
.loading-inline::before {
  content: "";
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-inline .loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 紧凑内联加载（用于局部刷新） */
.loading-compact {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 0;
}
.loading-compact::before {
  content: "";
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #E0E0E0;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}
.loading-compact .loading-text {
  font-size: 24rpx;
  color: #BBB;
}

/* 错误重试按钮 */
.retry-btn {
  width: 200rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  color: var(--primary);
  background: #FFF;
  border: 1rpx solid var(--primary);
  border-radius: 32rpx;
  text-align: center;
  padding: 0;
  margin-top: 24rpx;
}
.retry-btn::after { border: none; }
.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}
